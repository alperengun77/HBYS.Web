@model HBYS.Web.ViewModels.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HBYS Giriş</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            body {
                background: linear-gradient(135deg, #1f3c88, #0b132b);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: Arial, sans-serif;
            }

            .login-card {
                width: 420px;
                background-color: white;
                border-radius: 18px;
                padding: 35px;
                box-shadow: 0 15px 40px rgba(0, 0, 0, 0.35);
            }

            .login-title {
                text-align: center;
                font-weight: bold;
                color: #1f3c88;
                margin-bottom: 5px;
            }

            .login-subtitle {
                text-align: center;
                color: #6c757d;
                margin-bottom: 30px;
            }

            .btn-login {
                background-color: #1f3c88;
                color: white;
                font-weight: bold;
                width: 100%;
            }

            .btn-login:hover {
                background-color: #162d66;
                color: white;
            }

            .hospital-icon {
                font-size: 48px;
                text-align: center;
                margin-bottom: 10px;
            }

            .info-box {
                background-color: #f1f5ff;
                border-left: 4px solid #1f3c88;
                padding: 10px;
                font-size: 14px;
                margin-top: 20px;
            }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="hospital-icon">🏥</div>

        <h3 class="login-title">HBYS Web</h3>
        <p class="login-subtitle">Hastane Bilgi Yönetim Sistemi</p>

        <form asp-controller="Account" asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="KullaniciAdi" class="form-label"></label>
                <input asp-for="KullaniciAdi" class="form-control" placeholder="Kullanıcı adınızı giriniz" />
                <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Sifre" class="form-label"></label>
                <input asp-for="Sifre" class="form-control" placeholder="Şifrenizi giriniz" />
                <span asp-validation-for="Sifre" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-login mt-2">Giriş Yap</button>
        </form>

        <div class="info-box">
            <strong>Demo kullanıcı:</strong><br />
            Kullanıcı adı: admin<br />
            Şifre: 1234
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
