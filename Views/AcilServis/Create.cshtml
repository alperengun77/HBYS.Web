@model HBYS.Web.Models.AcilBasvuru

@{
    ViewData["Title"] = "Yeni Acil Başvurusu";

    bool doktorMu =
        ViewBag.DoktorMu == true;
}

<div class="page-card">
    <div class="mb-4">
        <h3>🚑 Yeni Acil Başvurusu</h3>

        <p class="text-muted mb-0">
            Hastayı TC kimlik numarasıyla bul,
            hayati bulguları kaydet ve triyaj seviyesini belirle.
        </p>
    </div>

    <form asp-controller="AcilServis"
          asp-action="Create"
          method="post">

        @Html.AntiForgeryToken()

        <input type="hidden"
               asp-for="HastaId"
               id="hastaIdInput" />

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>1. Hasta Bul</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-lg-8">
                        <label for="tcKimlikNoInput"
                               class="form-label">
                            Hasta TC Kimlik No
                        </label>

                        <input type="text"
                               id="tcKimlikNoInput"
                               value="@ViewBag.HastaTc"
                               class="form-control only-digits"
                               maxlength="11"
                               inputmode="numeric"
                               placeholder="11 haneli TC kimlik numarası" />
                    </div>

                    <div class="col-lg-4 d-flex align-items-end">
                        <button type="button"
                                id="hastaBulButton"
                                class="btn btn-main w-100">
                            Hastayı Bul
                        </button>
                    </div>

                    <div class="col-md-12">
                        <span asp-validation-for="HastaId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <div id="hastaMesaji"
                             class="alert d-none mb-0">
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">
                            Hasta
                        </label>

                        <input type="text"
                               id="hastaBilgisiInput"
                               value="@ViewBag.HastaBilgisi"
                               class="form-control"
                               readonly
                               placeholder="Hasta bulununca burada görünecek" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">
                            Doğum Tarihi
                        </label>

                        <input type="text"
                               id="dogumTarihiInput"
                               class="form-control"
                               readonly />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">
                            Kan Grubu
                        </label>

                        <input type="text"
                               id="kanGrubuInput"
                               class="form-control"
                               readonly />
                    </div>

                    <div class="col-md-12">
                        <a asp-controller="Hasta"
                           asp-action="Create"
                           target="_blank"
                           class="btn btn-sm btn-outline-primary">
                            Hasta Bulunamadıysa Yeni Hasta Kaydı Aç
                        </a>

                        <small class="text-muted ms-2">
                            Hasta kaydını yeni sekmede oluşturup
                            bu sayfaya dönerek tekrar arayabilirsin.
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>2. Başvuru ve Triyaj</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="BasvuruTarihi"
                               class="form-label">
                            Başvuru Tarihi
                        </label>

                        <input asp-for="BasvuruTarihi"
                               type="datetime-local"
                               step="60"
                               max="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                               value="@Model.BasvuruTarihi.ToString("yyyy-MM-ddTHH:mm")"
                               class="form-control" />

                        <span asp-validation-for="BasvuruTarihi"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="GelisSekli"
                               class="form-label">
                            Geliş Şekli
                        </label>

                        <select asp-for="GelisSekli"
                                asp-items="ViewBag.GelisSekilleri"
                                class="form-select">
                        </select>

                        <span asp-validation-for="GelisSekli"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TriyajSeviyesi"
                               class="form-label">
                            Triyaj Seviyesi
                        </label>

                        <select asp-for="TriyajSeviyesi"
                                asp-items="ViewBag.TriyajSeviyeleri"
                                class="form-select">
                        </select>

                        <span asp-validation-for="TriyajSeviyesi"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Sikayet"
                               class="form-label">
                            Başvuru Şikâyeti
                        </label>

                        <textarea asp-for="Sikayet"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Hastanın acil servise geliş şikâyetini yazınız...">
                        </textarea>

                        <span asp-validation-for="Sikayet"
                              class="text-danger">
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>3. Hayati Bulgular</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="Ates"
                               class="form-label">
                            Ateş
                        </label>

                        <div class="input-group">
                            <input asp-for="Ates"
                                   type="number"
                                   step="0.1"
                                   min="30"
                                   max="45"
                                   class="form-control"
                                   placeholder="36.5" />

                            <span class="input-group-text">
                                °C
                            </span>
                        </div>

                        <span asp-validation-for="Ates"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Nabiz"
                               class="form-label">
                            Nabız
                        </label>

                        <div class="input-group">
                            <input asp-for="Nabiz"
                                   type="number"
                                   min="20"
                                   max="250"
                                   class="form-control" />

                            <span class="input-group-text">
                                /dk
                            </span>
                        </div>

                        <span asp-validation-for="Nabiz"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TansiyonSistolik"
                               class="form-label">
                            Büyük Tansiyon
                        </label>

                        <input asp-for="TansiyonSistolik"
                               type="number"
                               min="50"
                               max="250"
                               class="form-control" />

                        <span asp-validation-for="TansiyonSistolik"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TansiyonDiastolik"
                               class="form-label">
                            Küçük Tansiyon
                        </label>

                        <input asp-for="TansiyonDiastolik"
                               type="number"
                               min="30"
                               max="180"
                               class="form-control" />

                        <span asp-validation-for="TansiyonDiastolik"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="OksijenSaturasyonu"
                               class="form-label">
                            Oksijen Satürasyonu
                        </label>

                        <div class="input-group">
                            <input asp-for="OksijenSaturasyonu"
                                   type="number"
                                   min="50"
                                   max="100"
                                   class="form-control" />

                            <span class="input-group-text">
                                %
                            </span>
                        </div>

                        <span asp-validation-for="OksijenSaturasyonu"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="SolunumSayisi"
                               class="form-label">
                            Solunum Sayısı
                        </label>

                        <div class="input-group">
                            <input asp-for="SolunumSayisi"
                                   type="number"
                                   min="5"
                                   max="80"
                                   class="form-control" />

                            <span class="input-group-text">
                                /dk
                            </span>
                        </div>

                        <span asp-validation-for="SolunumSayisi"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="BilincDurumu"
                               class="form-label">
                            Bilinç Durumu
                        </label>

                        <select asp-for="BilincDurumu"
                                asp-items="ViewBag.BilincDurumlari"
                                class="form-select">

                            <option value="">
                                Seçiniz
                            </option>
                        </select>

                        <span asp-validation-for="BilincDurumu"
                              class="text-danger">
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>4. Doktor ve Müdahale</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="DoktorId"
                               class="form-label">
                            Acil Servis Doktoru
                        </label>

                        @if (doktorMu)
                        {
                            <select asp-for="DoktorId"
                                    asp-items="ViewBag.Doktorlar"
                                    class="form-select"
                                    disabled>
                            </select>

                            <input type="hidden"
                                   asp-for="DoktorId" />
                        }
                        else
                        {
                            <select asp-for="DoktorId"
                                    asp-items="ViewBag.Doktorlar"
                                    class="form-select">

                                <option value="">
                                    Henüz Doktor Atanmadı
                                </option>
                            </select>
                        }

                        <span asp-validation-for="DoktorId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Durum"
                               class="form-label">
                            Başvuru Durumu
                        </label>

                        <select asp-for="Durum"
                                asp-items="ViewBag.BasvuruDurumlari"
                                class="form-select">
                        </select>

                        <span asp-validation-for="Durum"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="MudahaleNotu"
                               class="form-label">
                            Müdahale Notu
                        </label>

                        <textarea asp-for="MudahaleNotu"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Yapılan müdahaleler, uygulanan ilaçlar ve gözlem notları...">
                        </textarea>

                        <span asp-validation-for="MudahaleNotu"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Sonuc"
                               class="form-label">
                            Sonuç
                        </label>

                        <textarea asp-for="Sonuc"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Taburcu, yatış veya sevk sonucunu yazınız...">
                        </textarea>

                        <span asp-validation-for="Sonuc"
                              class="text-danger">
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <button type="submit"
                class="btn btn-danger">
            Acil Başvurusunu Kaydet
        </button>

        <a asp-controller="AcilServis"
           asp-action="Index"
           class="btn btn-secondary">
            Geri Dön
        </a>
    </form>
</div>

<script>
    document.addEventListener(
        "DOMContentLoaded",
        function () {
            const tcInput =
                document.getElementById(
                    "tcKimlikNoInput"
                );

            const hastaBulButton =
                document.getElementById(
                    "hastaBulButton"
                );

            const hastaIdInput =
                document.getElementById(
                    "hastaIdInput"
                );

            const hastaBilgisiInput =
                document.getElementById(
                    "hastaBilgisiInput"
                );

            const dogumTarihiInput =
                document.getElementById(
                    "dogumTarihiInput"
                );

            const kanGrubuInput =
                document.getElementById(
                    "kanGrubuInput"
                );

            const hastaMesaji =
                document.getElementById(
                    "hastaMesaji"
                );

            const hastaGetirUrl =
                '@Url.Action(
                                        "HastaGetir",
                                        "AcilServis"
                                )';

            function mesajGoster(
                mesaj,
                basarili
            ) {
                hastaMesaji.classList.remove(
                    "d-none",
                    "alert-success",
                    "alert-danger"
                );

                hastaMesaji.classList.add(
                    basarili
                        ? "alert-success"
                        : "alert-danger"
                );

                hastaMesaji.textContent =
                    mesaj;
            }

            function hastayiTemizle() {
                hastaIdInput.value =
                    "";

                hastaBilgisiInput.value =
                    "";

                dogumTarihiInput.value =
                    "";

                kanGrubuInput.value =
                    "";
            }

            function hastayiBul() {
                const tcKimlikNo =
                    tcInput.value.trim();

                hastayiTemizle();

                if (tcKimlikNo.length !== 11) {
                    mesajGoster(
                        "TC kimlik numarası 11 haneli olmalıdır.",
                        false
                    );

                    return;
                }

                hastaBulButton.disabled =
                    true;

                hastaBulButton.textContent =
                    "Aranıyor...";

                fetch(
                    `${hastaGetirUrl}?tcKimlikNo=${encodeURIComponent(tcKimlikNo)}`
                )
                    .then(response => {
                        if (!response.ok) {
                            throw new Error();
                        }

                        return response.json();
                    })
                    .then(data => {
                        if (!data.basarili) {
                            mesajGoster(
                                data.mesaj,
                                false
                            );

                            return;
                        }

                        hastaIdInput.value =
                            data.hasta.hastaId;

                        hastaBilgisiInput.value =
                            data.hasta.tcKimlikNo +
                            " - " +
                            data.hasta.adSoyad;

                        dogumTarihiInput.value =
                            data.hasta.dogumTarihi;

                        kanGrubuInput.value =
                            data.hasta.kanGrubu;

                        mesajGoster(
                            "Hasta bulundu. Acil başvurusu oluşturulabilir.",
                            true
                        );
                    })
                    .catch(() => {
                        mesajGoster(
                            "Hasta bilgileri alınırken hata oluştu.",
                            false
                        );
                    })
                    .finally(() => {
                        hastaBulButton.disabled =
                            false;

                        hastaBulButton.textContent =
                            "Hastayı Bul";
                    });
            }

            hastaBulButton.addEventListener(
                "click",
                hastayiBul
            );

            tcInput.addEventListener(
                "keydown",
                function (event) {
                    if (event.key === "Enter") {
                        event.preventDefault();
                        hastayiBul();
                    }
                }
            );
        }
    );
</script>