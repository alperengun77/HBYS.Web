@model HBYS.Web.Models.AcilBasvuru

@{
    ViewData["Title"] = "Acil Başvurusu Güncelle";

    bool doktorMu =
        ViewBag.DoktorMu == true;
}

<div class="page-card">
    <div class="mb-4">
        <h3>🚑 Acil Başvurusu Güncelle</h3>

        <p class="text-muted mb-0">
            Hayati bulguları, triyajı,
            doktor atamasını ve müdahale sonucunu güncelle.
        </p>
    </div>

    <form asp-controller="AcilServis"
          asp-action="Edit"
          method="post">

        @Html.AntiForgeryToken()

        <input type="hidden"
               asp-for="AcilBasvuruId" />

        <input type="hidden"
               asp-for="HastaId" />

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>Hasta Bilgileri</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">
                            Hasta
                        </label>

                        <input type="text"
                               value="@ViewBag.HastaBilgisi"
                               class="form-control"
                               readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">
                            TC Kimlik No
                        </label>

                        <input type="text"
                               value="@ViewBag.HastaTc"
                               class="form-control"
                               readonly />
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>Başvuru ve Triyaj</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="BasvuruTarihi"
                               class="form-label">
                            Başvuru Tarihi
                        </label>

                        <input asp-for="BasvuruTarihi"
                               type="datetime-local"
                               step="60"
                               max="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                               value="@Model.BasvuruTarihi.ToString("yyyy-MM-ddTHH:mm")"
                               class="form-control" />

                        <span asp-validation-for="BasvuruTarihi"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="GelisSekli"
                               class="form-label">
                            Geliş Şekli
                        </label>

                        <select asp-for="GelisSekli"
                                asp-items="ViewBag.GelisSekilleri"
                                class="form-select">
                        </select>

                        <span asp-validation-for="GelisSekli"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="TriyajSeviyesi"
                               class="form-label">
                            Triyaj Seviyesi
                        </label>

                        <select asp-for="TriyajSeviyesi"
                                asp-items="ViewBag.TriyajSeviyeleri"
                                class="form-select">
                        </select>

                        <span asp-validation-for="TriyajSeviyesi"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Sikayet"
                               class="form-label">
                            Başvuru Şikâyeti
                        </label>

                        <textarea asp-for="Sikayet"
                                  class="form-control"
                                  rows="3">
                        </textarea>

                        <span asp-validation-for="Sikayet"
                              class="text-danger">
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>Hayati Bulgular</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="Ates"
                               class="form-label">
                            Ateş
                        </label>

                        <div class="input-group">
                            <input asp-for="Ates"
                                   type="number"
                                   step="0.1"
                                   min="30"
                                   max="45"
                                   class="form-control" />

                            <span class="input-group-text">
                                °C
                            </span>
                        </div>

                        <span asp-validation-for="Ates"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Nabiz"
                               class="form-label">
                            Nabız
                        </label>

                        <input asp-for="Nabiz"
                               type="number"
                               min="20"
                               max="250"
                               class="form-control" />

                        <span asp-validation-for="Nabiz"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TansiyonSistolik"
                               class="form-label">
                            Büyük Tansiyon
                        </label>

                        <input asp-for="TansiyonSistolik"
                               type="number"
                               min="50"
                               max="250"
                               class="form-control" />

                        <span asp-validation-for="TansiyonSistolik"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TansiyonDiastolik"
                               class="form-label">
                            Küçük Tansiyon
                        </label>

                        <input asp-for="TansiyonDiastolik"
                               type="number"
                               min="30"
                               max="180"
                               class="form-control" />

                        <span asp-validation-for="TansiyonDiastolik"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="OksijenSaturasyonu"
                               class="form-label">
                            Oksijen
                        </label>

                        <div class="input-group">
                            <input asp-for="OksijenSaturasyonu"
                                   type="number"
                                   min="50"
                                   max="100"
                                   class="form-control" />

                            <span class="input-group-text">
                                %
                            </span>
                        </div>

                        <span asp-validation-for="OksijenSaturasyonu"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="SolunumSayisi"
                               class="form-label">
                            Solunum
                        </label>

                        <input asp-for="SolunumSayisi"
                               type="number"
                               min="5"
                               max="80"
                               class="form-control" />

                        <span asp-validation-for="SolunumSayisi"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="BilincDurumu"
                               class="form-label">
                            Bilinç Durumu
                        </label>

                        <select asp-for="BilincDurumu"
                                asp-items="ViewBag.BilincDurumlari"
                                class="form-select">

                            <option value="">
                                Seçiniz
                            </option>
                        </select>

                        <span asp-validation-for="BilincDurumu"
                              class="text-danger">
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>Doktor ve Müdahale</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="DoktorId"
                               class="form-label">
                            Acil Servis Doktoru
                        </label>

                        @if (doktorMu)
                        {
                            <select asp-for="DoktorId"
                                    asp-items="ViewBag.Doktorlar"
                                    class="form-select"
                                    disabled>
                            </select>

                            <input type="hidden"
                                   asp-for="DoktorId" />
                        }
                        else
                        {
                            <select asp-for="DoktorId"
                                    asp-items="ViewBag.Doktorlar"
                                    class="form-select">

                                <option value="">
                                    Henüz Doktor Atanmadı
                                </option>
                            </select>
                        }

                        <span asp-validation-for="DoktorId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Durum"
                               class="form-label">
                            Başvuru Durumu
                        </label>

                        <select asp-for="Durum"
                                asp-items="ViewBag.BasvuruDurumlari"
                                class="form-select">
                        </select>

                        <span asp-validation-for="Durum"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="MudahaleNotu"
                               class="form-label">
                            Müdahale Notu
                        </label>

                        <textarea asp-for="MudahaleNotu"
                                  class="form-control"
                                  rows="5">
                        </textarea>

                        <span asp-validation-for="MudahaleNotu"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Sonuc"
                               class="form-label">
                            Sonuç
                        </label>

                        <textarea asp-for="Sonuc"
                                  class="form-control"
                                  rows="3">
                        </textarea>

                        <span asp-validation-for="Sonuc"
                              class="text-danger">
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <button type="submit"
                class="btn btn-warning">
            Güncelle
        </button>

        <a asp-controller="AcilServis"
           asp-action="Details"
           asp-route-id="@Model.AcilBasvuruId"
           class="btn btn-secondary">
            Geri Dön
        </a>
    </form>
</div>