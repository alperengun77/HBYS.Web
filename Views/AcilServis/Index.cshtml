@model List<HBYS.Web.Models.AcilBasvuru>

@{
    ViewData["Title"] = "Acil Servis";

    bool adminMi =
        ViewBag.AdminMi == true;
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>🚑 Acil Servis ve Triyaj</h3>

            <p class="text-muted mb-0">
                Acil başvurularını, triyaj seviyelerini
                ve müdahale süreçlerini takip et.
            </p>
        </div>

        <a asp-controller="AcilServis"
           asp-action="Create"
           class="btn btn-danger">
            Yeni Acil Başvurusu
        </a>
    </div>

    <form asp-controller="AcilServis"
          asp-action="Index"
          method="get"
          class="row g-2 mb-4">

        <div class="col-lg-4">
            <input type="text"
                   name="arama"
                   value="@ViewBag.Arama"
                   class="form-control"
                   placeholder="TC, hasta, doktor veya şikâyet ara..." />
        </div>

        <div class="col-lg-2">
            <input type="date"
                   name="tarih"
                   value="@ViewBag.Tarih"
                   class="form-control" />
        </div>

        <div class="col-lg-2">
            <select name="triyajSeviyesi"
                    asp-items="ViewBag.TriyajFiltreListesi"
                    class="form-select">

                <option value="">
                    Tüm Triyajlar
                </option>
            </select>
        </div>

        <div class="col-lg-2">
            <select name="durum"
                    asp-items="ViewBag.DurumFiltreListesi"
                    class="form-select">

                <option value="">
                    Tüm Durumlar
                </option>
            </select>
        </div>

        <div class="col-lg-1">
            <button type="submit"
                    class="btn btn-main w-100">
                Ara
            </button>
        </div>

        <div class="col-lg-1">
            <a asp-controller="AcilServis"
               asp-action="Index"
               class="btn btn-outline-secondary w-100">
                Sil
            </a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Başvuru</th>
                    <th>Triyaj</th>
                    <th>Hasta</th>
                    <th>Geliş</th>
                    <th>Şikâyet</th>
                    <th>Doktor</th>
                    <th>Durum</th>
                    <th style="min-width: 230px;">
                        İşlemler
                    </th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="8"
                            class="text-center text-muted">
                            Acil Servis başvurusu bulunamadı.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var basvuru in Model)
                    {
                        string triyajSinifi =
                            basvuru.TriyajSeviyesi switch
                            {
                                "Kırmızı" =>
                                    "bg-danger",

                                "Sarı" =>
                                    "bg-warning text-dark",

                                "Yeşil" =>
                                    "bg-success",

                                "Siyah" =>
                                    "bg-dark",

                                _ =>
                                    "bg-secondary"
                            };

                        string durumSinifi =
                            basvuru.Durum switch
                            {
                                "Bekliyor" =>
                                    "bg-warning text-dark",

                                "Doktor Atandı" =>
                                    "bg-info text-dark",

                                "Muayenede" =>
                                    "bg-primary",

                                "Gözlemde" =>
                                    "bg-secondary",

                                "Yatış Verildi" =>
                                    "bg-dark",

                                "Taburcu" =>
                                    "bg-success",

                                "Sevk Edildi" =>
                                    "bg-danger",

                                _ =>
                                    "bg-secondary"
                            };

                        <tr>
                            <td>
                                <strong>
                                    @basvuru.BasvuruTarihi.ToString("dd.MM.yyyy")
                                </strong>

                                <br />

                                <span class="text-muted">
                                    @basvuru.BasvuruTarihi.ToString("HH:mm")
                                </span>
                            </td>

                            <td>
                                <span class="badge @triyajSinifi fs-6">
                                    @basvuru.TriyajSeviyesi
                                </span>
                            </td>

                            <td>
                                <strong>
                                    @basvuru.Hasta?.Ad
                                    @basvuru.Hasta?.Soyad
                                </strong>

                                <br />

                                <small class="text-muted">
                                    @basvuru.Hasta?.TcKimlikNo
                                </small>
                            </td>

                            <td>
                                @basvuru.GelisSekli
                            </td>

                            <td style="max-width: 250px;">
                                @basvuru.Sikayet
                            </td>

                            <td>
                                @if (basvuru.Doktor == null)
                                {
                                    <span class="text-muted">
                                        Atanmadı
                                    </span>
                                }
                                else
                                {
                                    @basvuru.Doktor.Unvan
                                    @basvuru.Doktor.Ad
                                    @basvuru.Doktor.Soyad
                                }
                            </td>

                            <td>
                                <span class="badge @durumSinifi">
                                    @basvuru.Durum
                                </span>
                            </td>

                            <td>
                                <a asp-controller="AcilServis"
                                   asp-action="Details"
                                   asp-route-id="@basvuru.AcilBasvuruId"
                                   class="btn btn-sm btn-info mb-1">
                                    Detay
                                </a>

                                <a asp-controller="AcilServis"
                                   asp-action="Edit"
                                   asp-route-id="@basvuru.AcilBasvuruId"
                                   class="btn btn-sm btn-warning mb-1">
                                    Güncelle
                                </a>

                                @if (adminMi)
                                {
                                    <form asp-controller="AcilServis"
                                          asp-action="Delete"
                                          asp-route-id="@basvuru.AcilBasvuruId"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Bu Acil Servis kaydı silinsin mi?');">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-sm btn-danger mb-1">
                                            Sil
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>