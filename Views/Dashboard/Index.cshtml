@using HBYS.Web.Models

@{
    ViewData["Title"] = "Dashboard";

    var sonRandevular = ViewBag.SonRandevular as List<Randevu>;
    var sonMuayeneler = ViewBag.SonMuayeneler as List<Muayene>;
    var sonReceteler = ViewBag.SonReceteler as List<Recete>;
    var sonTahliller = ViewBag.SonTahliller as List<Tahlil>;

    bool adminMi = ViewBag.AdminMi == true;
    bool doktorMu = ViewBag.DoktorMu == true;
    bool sekreterMi = ViewBag.SekreterMi == true;
    bool laborantMi = ViewBag.LaborantMi == true;
    bool eczaneMi = ViewBag.EczaneMi == true;
    bool yoneticiMi = ViewBag.YoneticiMi == true;

    bool canHasta = adminMi || yoneticiMi || sekreterMi || doktorMu || laborantMi || eczaneMi;
    bool canDoktor = adminMi || yoneticiMi || sekreterMi || doktorMu;
    bool canPoliklinik = adminMi || yoneticiMi || sekreterMi || doktorMu;
    bool canRandevu = adminMi || yoneticiMi || sekreterMi || doktorMu;
    bool canMuayene = adminMi || yoneticiMi || doktorMu;
    bool canRecete = adminMi || yoneticiMi || doktorMu || eczaneMi;
    bool canTahlil = adminMi || yoneticiMi || doktorMu || laborantMi;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>@ViewBag.DashboardBaslik</h2>

            <p class="text-muted mb-1">
                Hoş geldiniz, <strong>@ViewBag.AdSoyad</strong> |
                Yetki: <strong>@ViewBag.YetkiAdi</strong>
            </p>

            <p class="text-muted mb-0">
                @ViewBag.DashboardAciklama
            </p>
        </div>

        <div class="col-md-4 text-end">
            <span class="badge bg-primary fs-6">
                @DateTime.Now.ToString("dd.MM.yyyy HH:mm")
            </span>
        </div>
    </div>

    @if (ViewBag.DashboardUyarisi != null)
    {
        <div class="alert alert-warning">
            @ViewBag.DashboardUyarisi
        </div>
    }

    <div class="row g-3">
        @if (canHasta)
        {
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            @(doktorMu || laborantMi || eczaneMi ? "İlgili Hasta" : "Hasta Sayısı")
                        </h6>
                        <h2>@ViewBag.HastaSayisi</h2>
                        <p class="mb-0">
                            @(doktorMu ? "Size bağlı hastalar" : "Aktif hasta kayıtları")
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (canDoktor)
        {
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            @(doktorMu ? "Doktor Kaydınız" : "Doktor Sayısı")
                        </h6>
                        <h2>@ViewBag.DoktorSayisi</h2>
                        <p class="mb-0">
                            @(doktorMu ? "Bağlı doktor hesabı" : "Aktif doktor kayıtları")
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (canPoliklinik)
        {
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            @(doktorMu ? "Bağlı Poliklinik" : "Poliklinik Sayısı")
                        </h6>
                        <h2>@ViewBag.PoliklinikSayisi</h2>
                        <p class="mb-0">
                            @(doktorMu ? "Doktorun bağlı olduğu bölüm" : "Aktif poliklinikler")
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (canRandevu)
        {
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Toplam Randevu</h6>
                        <h2>@ViewBag.RandevuSayisi</h2>
                        <p class="mb-0">
                            @(doktorMu ? "Size ait randevular" : "Aktif randevu kayıtları")
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row g-3 mt-1">
        @if (canRandevu)
        {
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Bugünkü Randevu</h6>
                        <h2>@ViewBag.BugunRandevuSayisi</h2>
                        <p class="mb-0">Bugüne ait randevular</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Bekleyen Randevu</h6>
                        <h2>@ViewBag.BekleyenRandevuSayisi</h2>
                        <p class="mb-0">Henüz tamamlanmamış</p>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Tamamlanan Randevu</h6>
                        <h2>@ViewBag.TamamlananRandevuSayisi</h2>
                        <p class="mb-0">Tamamlanan kayıtlar</p>
                    </div>
                </div>
            </div>
        }

        @if (canMuayene)
        {
            <div class="col-md-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Muayene Sayısı</h6>
                        <h2>@ViewBag.MuayeneSayisi</h2>
                        <p class="mb-0">
                            @(doktorMu ? "Size ait muayeneler" : "Aktif muayene kayıtları")
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row g-3 mt-1">
        @if (canMuayene)
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Bugünkü Muayene</h6>
                        <h2>@ViewBag.BugunMuayeneSayisi</h2>
                        <p class="mb-0">Bugün yapılan muayeneler</p>
                    </div>
                </div>
            </div>
        }

        @if (canRecete)
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Reçete Sayısı</h6>
                        <h2>@ViewBag.ReceteSayisi</h2>
                        <p class="mb-0">
                            @(doktorMu ? "Size bağlı reçeteler" : "Aktif reçete kayıtları")
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (canTahlil)
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Tahlil Sayısı</h6>
                        <h2>@ViewBag.TahlilSayisi</h2>
                        <p class="mb-0">
                            @(doktorMu ? "Size bağlı tahliller" : "Aktif tahlil kayıtları")
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (canTahlil)
    {
        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">Bekleyen Tahlil</h6>
                        <h2>@ViewBag.BekleyenTahlilSayisi</h2>
                        <p class="mb-0">Sonuçlanmamış tahliller</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="page-card mt-4">
        <h5>Hızlı İşlemler</h5>
        <hr />

        <div class="row g-2">
            @if (adminMi || sekreterMi || doktorMu)
            {
                <div class="col-md-3">
                    <a asp-controller="Hasta" asp-action="Index" class="btn btn-outline-primary w-100">
                        Hasta İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || sekreterMi || yoneticiMi)
            {
                <div class="col-md-3">
                    <a asp-controller="Doktor" asp-action="Index" class="btn btn-outline-primary w-100">
                        Doktor İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || yoneticiMi)
            {
                <div class="col-md-3">
                    <a asp-controller="Poliklinik" asp-action="Index" class="btn btn-outline-primary w-100">
                        Poliklinik İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || sekreterMi || doktorMu)
            {
                <div class="col-md-3">
                    <a asp-controller="Randevu" asp-action="Index" class="btn btn-outline-primary w-100">
                        Randevu İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || doktorMu)
            {
                <div class="col-md-3">
                    <a asp-controller="Muayene" asp-action="Index" class="btn btn-outline-success w-100">
                        Muayene İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || doktorMu || eczaneMi)
            {
                <div class="col-md-3">
                    <a asp-controller="Recete" asp-action="Index" class="btn btn-outline-success w-100">
                        Reçete İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || doktorMu || laborantMi)
            {
                <div class="col-md-3">
                    <a asp-controller="Tahlil" asp-action="Index" class="btn btn-outline-success w-100">
                        Tahlil İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || yoneticiMi || sekreterMi || doktorMu)
            {
                <div class="col-md-3">
                    <a asp-controller="Rapor" asp-action="Index" class="btn btn-outline-dark w-100">
                        Raporlar
                    </a>
                </div>
            }
        </div>
    </div>

    @if (canRandevu)
    {
        <div class="page-card mt-4">
            <h5>@(doktorMu ? "Size Ait Son Randevular" : "Son Randevular")</h5>
            <hr />

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Hasta</th>
                            <th>Doktor</th>
                            <th>Poliklinik</th>
                            <th>Durum</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (sonRandevular == null || sonRandevular.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">
                                    Randevu bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var randevu in sonRandevular)
                            {
                                <tr>
                                    <td>@randevu.RandevuTarihiSaati.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@randevu.Hasta?.Ad @randevu.Hasta?.Soyad</td>
                                    <td>@randevu.Doktor?.Ad @randevu.Doktor?.Soyad</td>
                                    <td>@randevu.Poliklinik?.PoliklinikAdi</td>
                                    <td>@randevu.Durum</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (canMuayene)
    {
        <div class="page-card mt-4">
            <h5>@(doktorMu ? "Size Ait Son Muayeneler" : "Son Muayeneler")</h5>
            <hr />

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Hasta</th>
                            <th>Doktor</th>
                            <th>Tanı</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (sonMuayeneler == null || sonMuayeneler.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">
                                    Muayene bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var muayene in sonMuayeneler)
                            {
                                <tr>
                                    <td>@muayene.MuayeneTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@muayene.Hasta?.Ad @muayene.Hasta?.Soyad</td>
                                    <td>@muayene.Doktor?.Ad @muayene.Doktor?.Soyad</td>
                                    <td>@muayene.Tani</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (canRecete)
    {
        <div class="page-card mt-4">
            <h5>@(doktorMu ? "Size Bağlı Son Reçeteler" : "Son Reçeteler")</h5>
            <hr />

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Hasta</th>
                            <th>Doktor</th>
                            <th>İlaç</th>
                            <th>Kullanım</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (sonReceteler == null || sonReceteler.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">
                                    Reçete bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var recete in sonReceteler)
                            {
                                <tr>
                                    <td>@recete.KayitTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@recete.Muayene?.Hasta?.Ad @recete.Muayene?.Hasta?.Soyad</td>
                                    <td>@recete.Muayene?.Doktor?.Ad @recete.Muayene?.Doktor?.Soyad</td>
                                    <td>@recete.IlacAdi</td>
                                    <td>@recete.KullanimSekli</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (canTahlil)
    {
        <div class="page-card mt-4">
            <h5>@(doktorMu ? "Size Bağlı Son Tahliller" : "Son Tahliller")</h5>
            <hr />

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead>
                        <tr>
                            <th>İstenme Tarihi</th>
                            <th>Hasta</th>
                            <th>Doktor</th>
                            <th>Tahlil</th>
                            <th>Durum</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (sonTahliller == null || sonTahliller.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">
                                    Tahlil bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var tahlil in sonTahliller)
                            {
                                <tr>
                                    <td>@tahlil.IstenmeTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@tahlil.Muayene?.Hasta?.Ad @tahlil.Muayene?.Hasta?.Soyad</td>
                                    <td>@tahlil.Muayene?.Doktor?.Ad @tahlil.Muayene?.Doktor?.Soyad</td>
                                    <td>@tahlil.TahlilAdi</td>
                                    <td>@tahlil.Durum</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>