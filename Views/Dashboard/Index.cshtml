@using HBYS.Web.Models

@{
    ViewData["Title"] = "Dashboard";

    var gununRandevulari =
        ViewBag.GununRandevulari as List<Randevu>;

    var gununMuayeneleri =
        ViewBag.GununMuayeneleri as List<Muayene>;

    var gununReceteleri =
        ViewBag.GununReceteleri as List<Recete>;

    var gununTahlilleri =
        ViewBag.GununTahlilleri as List<Tahlil>;

    bool adminMi = ViewBag.AdminMi == true;
    bool doktorMu = ViewBag.DoktorMu == true;
    bool sekreterMi = ViewBag.SekreterMi == true;
    bool laborantMi = ViewBag.LaborantMi == true;
    bool eczaneMi = ViewBag.EczaneMi == true;
    bool yoneticiMi = ViewBag.YoneticiMi == true;

    bool canHasta =
        adminMi ||
        yoneticiMi ||
        sekreterMi ||
        doktorMu ||
        laborantMi ||
        eczaneMi;

    bool canDoktor =
        adminMi ||
        yoneticiMi ||
        sekreterMi ||
        doktorMu;

    bool canPoliklinik =
        adminMi ||
        yoneticiMi ||
        sekreterMi ||
        doktorMu;

    bool canRandevu =
        adminMi ||
        yoneticiMi ||
        sekreterMi ||
        doktorMu;

    bool canMuayene =
        adminMi ||
        yoneticiMi ||
        doktorMu;

    bool canRecete =
        adminMi ||
        yoneticiMi ||
        doktorMu ||
        eczaneMi;

    bool canTahlil =
        adminMi ||
        yoneticiMi ||
        doktorMu ||
        laborantMi;
}

<div class="container-fluid">
    <div class="row mb-4 align-items-center">
        <div class="col-lg-7">
            <h2>@ViewBag.DashboardBaslik</h2>

            <p class="text-muted mb-1">
                Hoş geldiniz,
                <strong>@ViewBag.AdSoyad</strong>
                |
                Yetki:
                <strong>@ViewBag.YetkiAdi</strong>
            </p>

            <p class="text-muted mb-0">
                @ViewBag.DashboardAciklama
            </p>
        </div>

        <div class="col-lg-5 mt-3 mt-lg-0">
            <form asp-controller="Dashboard"
                  asp-action="Index"
                  method="get"
                  class="row g-2 justify-content-lg-end">

                <div class="col-sm-7">
                    <label for="dashboardTarih"
                           class="form-label mb-1">
                        Görüntülenecek Gün
                    </label>

                    <input type="date"
                           id="dashboardTarih"
                           name="tarih"
                           value="@ViewBag.SeciliTarih"
                           class="form-control" />
                </div>

                <div class="col-sm-5 d-flex align-items-end">
                    <button type="submit"
                            class="btn btn-main w-100">
                        Günü Göster
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="page-card mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <div>
                <span class="text-muted">
                    Görüntülenen tarih:
                </span>

                <strong class="ms-1">
                    @ViewBag.SeciliTarihYazi
                </strong>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Dashboard"
                   asp-action="Index"
                   asp-route-tarih="@ViewBag.OncekiGun"
                   class="btn btn-outline-secondary btn-sm">
                    Önceki Gün
                </a>

                <a asp-controller="Dashboard"
                   asp-action="Index"
                   asp-route-tarih="@ViewBag.Bugun"
                   class="btn btn-outline-primary btn-sm">
                    Bugün
                </a>

                <a asp-controller="Dashboard"
                   asp-action="Index"
                   asp-route-tarih="@ViewBag.SonrakiGun"
                   class="btn btn-outline-secondary btn-sm">
                    Sonraki Gün
                </a>
            </div>
        </div>
    </div>

    @if (ViewBag.DashboardUyarisi != null)
    {
        <div class="alert alert-warning">
            @ViewBag.DashboardUyarisi
        </div>
    }

    <div class="row g-3">
        @if (canHasta)
        {
            <div class="col-md-6 col-xl-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            Günün Hasta Sayısı
                        </h6>

                        <h2>@ViewBag.HastaSayisi</h2>

                        <p class="mb-0">
                            @(doktorMu
                                ? "Size bağlı günlük hastalar"
                                : laborantMi
                                    ? "Tahlil işlemi olan hastalar"
                                    : eczaneMi
                                        ? "Reçete işlemi olan hastalar"
                                        : "Seçilen gün işlem gören hastalar")
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (canDoktor)
        {
            <div class="col-md-6 col-xl-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            @(doktorMu
                                ? "Doktor Kaydınız"
                                : "Görevli Doktor Sayısı")
                        </h6>

                        <h2>@ViewBag.DoktorSayisi</h2>

                        <p class="mb-0">
                            @(doktorMu
                                ? "Hesabınıza bağlı doktor kaydı"
                                : "Seçilen gün işlem yapan doktorlar")
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (canPoliklinik)
        {
            <div class="col-md-6 col-xl-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            Kullanılan Poliklinik
                        </h6>

                        <h2>@ViewBag.PoliklinikSayisi</h2>

                        <p class="mb-0">
                            Seçilen gün randevu bulunan bölümler
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (canRandevu)
        {
            <div class="col-md-6 col-xl-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            Günün Randevusu
                        </h6>

                        <h2>@ViewBag.RandevuSayisi</h2>

                        <p class="mb-0">
                            @(doktorMu
                                ? "Yalnızca size ait randevular"
                                : "Seçilen güne ait randevular")
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (canRandevu)
    {
        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            Bekleyen Randevu
                        </h6>

                        <h2>@ViewBag.BekleyenRandevuSayisi</h2>

                        <p class="mb-0">
                            Seçilen gün bekleyen kayıtlar
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            Tamamlanan Randevu
                        </h6>

                        <h2>@ViewBag.TamamlananRandevuSayisi</h2>

                        <p class="mb-0">
                            Muayenesi tamamlanan kayıtlar
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            İptal Edilen Randevu
                        </h6>

                        <h2>@ViewBag.IptalRandevuSayisi</h2>

                        <p class="mb-0">
                            Seçilen gün iptal edilen kayıtlar
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row g-3 mt-1">
        @if (canMuayene)
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            Günün Muayenesi
                        </h6>

                        <h2>@ViewBag.MuayeneSayisi</h2>

                        <p class="mb-0">
                            @(doktorMu
                                ? "Yalnızca sizin muayeneleriniz"
                                : "Seçilen gün yapılan muayeneler")
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (canRecete)
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            Günün Reçetesi
                        </h6>

                        <h2>@ViewBag.ReceteSayisi</h2>

                        <p class="mb-0">
                            @(doktorMu
                                ? "Sizin muayenelerinize bağlı reçeteler"
                                : "Seçilen gün oluşturulan reçeteler")
                        </p>
                    </div>
                </div>
            </div>
        }

        @if (canTahlil)
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            Günün Tahlili
                        </h6>

                        <h2>@ViewBag.TahlilSayisi</h2>

                        <p class="mb-0">
                            @(doktorMu
                                ? "Sizin muayenelerinize bağlı tahliller"
                                : "Seçilen gün istenen tahliller")
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (canTahlil)
    {
        <div class="row g-3 mt-1">
            <div class="col-md-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h6 class="text-muted">
                            Bekleyen Tahlil
                        </h6>

                        <h2>@ViewBag.BekleyenTahlilSayisi</h2>

                        <p class="mb-0">
                            Seçilen gün henüz sonuçlanmayan tahliller
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="page-card mt-4">
        <h5>Hızlı İşlemler</h5>
        <hr />

        <div class="row g-2">
            @if (adminMi || sekreterMi || doktorMu)
            {
                <div class="col-md-3">
                    <a asp-controller="Hasta"
                       asp-action="Index"
                       class="btn btn-outline-primary w-100">
                        Hasta İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || sekreterMi || yoneticiMi)
            {
                <div class="col-md-3">
                    <a asp-controller="Doktor"
                       asp-action="Index"
                       class="btn btn-outline-primary w-100">
                        Doktor İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || yoneticiMi)
            {
                <div class="col-md-3">
                    <a asp-controller="Poliklinik"
                       asp-action="Index"
                       class="btn btn-outline-primary w-100">
                        Poliklinik İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || sekreterMi || doktorMu)
            {
                <div class="col-md-3">
                    <a asp-controller="Randevu"
                       asp-action="Index"
                       class="btn btn-outline-primary w-100">
                        Randevu İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || doktorMu)
            {
                <div class="col-md-3">
                    <a asp-controller="Muayene"
                       asp-action="Index"
                       class="btn btn-outline-success w-100">
                        Muayene İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || doktorMu || eczaneMi)
            {
                <div class="col-md-3">
                    <a asp-controller="Recete"
                       asp-action="Index"
                       class="btn btn-outline-success w-100">
                        Reçete İşlemleri
                    </a>
                </div>
            }

            @if (adminMi || doktorMu || laborantMi)
            {
                <div class="col-md-3">
                    <a asp-controller="Tahlil"
                       asp-action="Index"
                       class="btn btn-outline-success w-100">
                        Tahlil İşlemleri
                    </a>
                </div>
            }

            @if (
                adminMi ||
                yoneticiMi ||
                sekreterMi ||
                doktorMu
            )
            {
                <div class="col-md-3">
                    <a asp-controller="Rapor"
                       asp-action="Index"
                       class="btn btn-outline-dark w-100">
                        Raporlar
                    </a>
                </div>
            }
        </div>
    </div>

    @if (canRandevu)
    {
        <div class="page-card mt-4">
            <h5>
                @ViewBag.SeciliTarihYazi Tarihli Randevular
            </h5>
            <hr />

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Saat</th>
                            <th>Hasta</th>
                            <th>Doktor</th>
                            <th>Poliklinik</th>
                            <th>Durum</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (
                            gununRandevulari == null ||
                            gununRandevulari.Count == 0
                        )
                        {
                            <tr>
                                <td colspan="5"
                                    class="text-center text-muted">
                                    Seçilen gün için randevu bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var randevu in gununRandevulari)
                            {
                                <tr>
                                    <td>
                                        @randevu.RandevuTarihiSaati.ToString("HH:mm")
                                    </td>

                                    <td>
                                        @randevu.Hasta?.Ad
                                        @randevu.Hasta?.Soyad
                                    </td>

                                    <td>
                                        @randevu.Doktor?.Ad
                                        @randevu.Doktor?.Soyad
                                    </td>

                                    <td>
                                        @randevu.Poliklinik?.PoliklinikAdi
                                    </td>

                                    <td>@randevu.Durum</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (canMuayene)
    {
        <div class="page-card mt-4">
            <h5>
                @ViewBag.SeciliTarihYazi Tarihli Muayeneler
            </h5>
            <hr />

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Saat</th>
                            <th>Hasta</th>
                            <th>Doktor</th>
                            <th>Tanı</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (
                            gununMuayeneleri == null ||
                            gununMuayeneleri.Count == 0
                        )
                        {
                            <tr>
                                <td colspan="4"
                                    class="text-center text-muted">
                                    Seçilen gün için muayene bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var muayene in gununMuayeneleri)
                            {
                                <tr>
                                    <td>
                                        @muayene.MuayeneTarihi.ToString("HH:mm")
                                    </td>

                                    <td>
                                        @muayene.Hasta?.Ad
                                        @muayene.Hasta?.Soyad
                                    </td>

                                    <td>
                                        @muayene.Doktor?.Ad
                                        @muayene.Doktor?.Soyad
                                    </td>

                                    <td>@muayene.Tani</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (canRecete)
    {
        <div class="page-card mt-4">
            <h5>
                @ViewBag.SeciliTarihYazi Tarihli Reçeteler
            </h5>
            <hr />

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Saat</th>
                            <th>Hasta</th>
                            <th>Doktor</th>
                            <th>İlaç</th>
                            <th>Kullanım</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (
                            gununReceteleri == null ||
                            gununReceteleri.Count == 0
                        )
                        {
                            <tr>
                                <td colspan="5"
                                    class="text-center text-muted">
                                    Seçilen gün için reçete bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var recete in gununReceteleri)
                            {
                                <tr>
                                    <td>
                                        @recete.KayitTarihi.ToString("HH:mm")
                                    </td>

                                    <td>
                                        @recete.Muayene?.Hasta?.Ad
                                        @recete.Muayene?.Hasta?.Soyad
                                    </td>

                                    <td>
                                        @recete.Muayene?.Doktor?.Ad
                                        @recete.Muayene?.Doktor?.Soyad
                                    </td>

                                    <td>@recete.IlacAdi</td>
                                    <td>@recete.KullanimSekli</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (canTahlil)
    {
        <div class="page-card mt-4">
            <h5>
                @ViewBag.SeciliTarihYazi Tarihli Tahliller
            </h5>
            <hr />

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Saat</th>
                            <th>Hasta</th>
                            <th>Doktor</th>
                            <th>Tahlil</th>
                            <th>Durum</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (
                            gununTahlilleri == null ||
                            gununTahlilleri.Count == 0
                        )
                        {
                            <tr>
                                <td colspan="5"
                                    class="text-center text-muted">
                                    Seçilen gün için tahlil bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var tahlil in gununTahlilleri)
                            {
                                <tr>
                                    <td>
                                        @tahlil.IstenmeTarihi.ToString("HH:mm")
                                    </td>

                                    <td>
                                        @tahlil.Muayene?.Hasta?.Ad
                                        @tahlil.Muayene?.Hasta?.Soyad
                                    </td>

                                    <td>
                                        @tahlil.Muayene?.Doktor?.Ad
                                        @tahlil.Muayene?.Doktor?.Soyad
                                    </td>

                                    <td>@tahlil.TahlilAdi</td>
                                    <td>@tahlil.Durum</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>