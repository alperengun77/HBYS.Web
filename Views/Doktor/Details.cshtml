@model HBYS.Web.Models.Doktor

@using HBYS.Web.Models

@{
    ViewData["Title"] = "Doktor Detay";

    var randevular = ViewBag.Randevular as List<Randevu>;
    var muayeneler = ViewBag.Muayeneler as List<Muayene>;
    var kullanicilar = ViewBag.Kullanicilar as List<Kullanici>;
}
<div class="print-header">
    <h2>HBYS Web</h2>
    <h4>Doktor Bilgi Kartı</h4>
    <p>Yazdırma Tarihi: @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</p>
</div>
<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Doktor Detay</h3>
            <p class="text-muted mb-0">Doktora ait bilgiler ve işlem geçmişi.</p>
        </div>

        <div class="no-print">
            <button type="button" onclick="window.print()" class="btn btn-main">
                Yazdır
            </button>

            <a asp-controller="Doktor" asp-action="Edit" asp-route-id="@Model.DoktorId" class="btn btn-warning">
                Güncelle
            </a>

            <a asp-controller="Doktor" asp-action="Index" class="btn btn-secondary">
                Geri Dön
            </a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5>@Model.Unvan @Model.Ad @Model.Soyad</h5>
                    <hr />

                    <p><strong>Sicil No:</strong> @Model.SicilNo</p>
                    <p><strong>Poliklinik:</strong> @Model.Poliklinik?.PoliklinikAdi</p>
                    <p><strong>Telefon:</strong> @Model.Telefon</p>
                    <p><strong>E-posta:</strong> @Model.Eposta</p>
                    <p><strong>Kayıt Tarihi:</strong> @Model.KayitTarihi.ToString("dd.MM.yyyy HH:mm")</p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="alert alert-primary">
                        <strong>Randevu</strong>
                        <h3>@(randevular?.Count ?? 0)</h3>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="alert alert-success">
                        <strong>Muayene</strong>
                        <h3>@(muayeneler?.Count ?? 0)</h3>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="alert alert-info">
                        <strong>Kullanıcı</strong>
                        <h3>@(kullanicilar?.Count ?? 0)</h3>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-2">
                <div class="card-body">
                    <h5>Doktor Özeti</h5>
                    <p class="text-muted mb-0">
                        Bu sayfada doktorun bağlı olduğu poliklinik, randevuları, muayeneleri ve sisteme bağlı kullanıcı hesabı görüntülenir.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-card mt-4">
    <h5>Doktor Randevuları</h5>
    <hr />

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Tarih / Saat</th>
                    <th>Hasta</th>
                    <th>Poliklinik</th>
                    <th>Durum</th>
                </tr>
            </thead>

            <tbody>
                @if (randevular == null || randevular.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">Randevu bulunamadı.</td>
                    </tr>
                }
                else
                {
                    foreach (var randevu in randevular)
                    {
                        <tr>
                            <td>@randevu.RandevuTarihiSaati.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@randevu.Hasta?.Ad @randevu.Hasta?.Soyad</td>
                            <td>@randevu.Poliklinik?.PoliklinikAdi</td>
                            <td>@randevu.Durum</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="page-card mt-4">
    <h5>Doktor Muayeneleri</h5>
    <hr />

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Muayene Tarihi</th>
                    <th>Hasta</th>
                    <th>Şikayet</th>
                    <th>Tanı</th>
                </tr>
            </thead>

            <tbody>
                @if (muayeneler == null || muayeneler.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">Muayene bulunamadı.</td>
                    </tr>
                }
                else
                {
                    foreach (var muayene in muayeneler)
                    {
                        <tr>
                            <td>@muayene.MuayeneTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@muayene.Hasta?.Ad @muayene.Hasta?.Soyad</td>
                            <td>@muayene.Sikayet</td>
                            <td>@muayene.Tani</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<div class="page-card mt-4">
    <h5>Bağlı Kullanıcı Hesapları</h5>
    <hr />

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Kullanıcı Adı</th>
                    <th>Ad Soyad</th>
                    <th>Rol</th>
                    <th>E-posta</th>
                </tr>
            </thead>

            <tbody>
                @if (kullanicilar == null || kullanicilar.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">Bağlı kullanıcı bulunamadı.</td>
                    </tr>
                }
                else
                {
                    foreach (var kullanici in kullanicilar)
                    {
                        <tr>
                            <td>@kullanici.KullaniciAdi</td>
                            <td>@kullanici.AdSoyad</td>
                            <td>@kullanici.Rol?.RolAdi</td>
                            <td>@kullanici.Eposta</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
