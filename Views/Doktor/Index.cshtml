@model List<HBYS.Web.Models.Doktor>

@{
    ViewData["Title"] = "Doktor İşlemleri";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Doktor İşlemleri</h3>
            <p class="text-muted mb-0">Doktor kayıtlarını listele, ara, ekle, güncelle ve sil.</p>
        </div>

        <a asp-controller="Doktor" asp-action="Create" class="btn btn-main">
            Yeni Doktor Ekle
        </a>
    </div>

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success">
            @TempData["Basari"]
        </div>
    }

    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Hata"]
        </div>
    }

    <form asp-controller="Doktor" asp-action="Index" method="get" class="row g-2 mb-3">
        <div class="col-md-10">
            <input type="text"
                   name="arama"
                   value="@ViewBag.Arama"
                   class="form-control"
                   placeholder="Sicil no, ad, soyad, unvan veya poliklinik ile ara..." />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">Ara</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Sicil No</th>
                    <th>Ad Soyad</th>
                    <th>Unvan</th>
                    <th>Poliklinik</th>
                    <th>Telefon</th>
                    <th>E-posta</th>
                    <th>Kayıt Tarihi</th>
                    <th style="width: 190px;">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            Kayıtlı doktor bulunamadı.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var doktor in Model)
                    {
                        <tr>
                            <td>@doktor.SicilNo</td>
                            <td>@doktor.Ad @doktor.Soyad</td>
                            <td>@doktor.Unvan</td>
                            <td>@doktor.Poliklinik?.PoliklinikAdi</td>
                            <td>@doktor.Telefon</td>
                            <td>@doktor.Eposta</td>
                            <td>@doktor.KayitTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <a asp-controller="Doktor"
                                   asp-action="Details"
                                   asp-route-id="@doktor.DoktorId"
                                   class="btn btn-sm btn-info">
                                    Detay
                                </a>
                                <a asp-controller="Doktor"
                                   asp-action="Edit"
                                   asp-route-id="@doktor.DoktorId"
                                   class="btn btn-sm btn-warning">
                                    Güncelle
                                </a>

                                <form asp-controller="Doktor"
                                      asp-action="Delete"
                                      asp-route-id="@doktor.DoktorId"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Bu doktoru silmek istediğinize emin misiniz?');">

                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Sil
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>