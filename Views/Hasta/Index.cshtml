@model List<HBYS.Web.Models.Hasta>

@{
    ViewData["Title"] = "Hasta İşlemleri";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Hasta İşlemleri</h3>
            <p class="text-muted mb-0">Hasta kayıtlarını listele, ara, ekle, güncelle ve sil.</p>
        </div>

        <a asp-controller="Hasta" asp-action="Create" class="btn btn-main">
            Yeni Hasta Ekle
        </a>
    </div>

    @if (TempData["Basari"] != null)
    {
        <div class="alert alert-success">
            @TempData["Basari"]
        </div>
    }

    @if (TempData["Hata"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Hata"]
        </div>
    }

    <form asp-controller="Hasta" asp-action="Index" method="get" class="row g-2 mb-3">
        <div class="col-md-4">
            <input type="text"
                   name="arama"
                   value="@ViewBag.Arama"
                   class="form-control"
                   placeholder="TC, ad, soyad, telefon veya e-posta ile ara..." />
        </div>

        <div class="col-md-2">
            <select name="cinsiyet" class="form-select">
                <option value="">Tüm Cinsiyetler</option>

                @if (ViewBag.Cinsiyet == "Erkek")
                {
                    <option value="Erkek" selected>Erkek</option>
                }
                else
                {
                    <option value="Erkek">Erkek</option>
                }

                @if (ViewBag.Cinsiyet == "Kadın")
                {
                    <option value="Kadın" selected>Kadın</option>
                }
                else
                {
                    <option value="Kadın">Kadın</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <select name="kanGrubu" class="form-select">
                <option value="">Tüm Kan Grupları</option>

                @{
                    string[] kanGruplari = { "A+", "A-", "B+", "B-", "AB+", "AB-", "0+", "0-" };
                }

                @foreach (var kan in kanGruplari)
                {
                    if (ViewBag.KanGrubu == kan)
                    {
                        <option value="@kan" selected>@kan</option>
                    }
                    else
                    {
                        <option value="@kan">@kan</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">Filtrele</button>
        </div>

        <div class="col-md-2">
            <a asp-controller="Hasta" asp-action="Index" class="btn btn-outline-secondary w-100">
                Temizle
            </a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>TC Kimlik No</th>
                    <th>Ad Soyad</th>
                    <th>Doğum Tarihi</th>
                    <th>Cinsiyet</th>
                    <th>Telefon</th>
                    <th>Kan Grubu</th>
                    <th>Kayıt Tarihi</th>
                    <th style="width: 190px;">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">
                            Kayıtlı hasta bulunamadı.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var hasta in Model)
                    {
                        <tr>
                            <td>@hasta.TcKimlikNo</td>
                            <td>@hasta.Ad @hasta.Soyad</td>
                            <td>@hasta.DogumTarihi.ToString("dd.MM.yyyy")</td>
                            <td>@hasta.Cinsiyet</td>
                            <td>@hasta.Telefon</td>
                            <td>@hasta.KanGrubu</td>
                            <td>@hasta.KayitTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <a asp-controller="Hasta"
                                   asp-action="Details"
                                   asp-route-id="@hasta.HastaId"
                                   class="btn btn-sm btn-info">
                                    Detay
                                </a>
                                <a asp-controller="Hasta"
                                   asp-action="Edit"
                                   asp-route-id="@hasta.HastaId"
                                   class="btn btn-sm btn-warning">
                                    Güncelle
                                </a>

                                <form asp-controller="Hasta"
                                      asp-action="Delete"
                                      asp-route-id="@hasta.HastaId"
                                      method="post"
                                      class="d-inline"
                                      onsubmit="return confirm('Bu hastayı silmek istediğinize emin misiniz?');">

                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="btn btn-sm btn-danger">
                                        Sil
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>