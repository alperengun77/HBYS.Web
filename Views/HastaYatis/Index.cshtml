@model List<HBYS.Web.Models.HastaYatis>

@{
    ViewData["Title"] = "Yatan Hastalar";

    bool yatisYetkisiVarMi =
        ViewBag.YatisYetkisiVarMi == true;

    bool taburcuYetkisiVarMi =
        ViewBag.TaburcuYetkisiVarMi == true;
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3>🏨 Yatan Hastalar</h3>

            <p class="text-muted mb-0">
                Devam eden yatışları, taburcu kayıtlarını
                ve hastaların bulunduğu yatakları görüntüle.
            </p>
        </div>

        @if (yatisYetkisiVarMi)
        {
            <a asp-controller="HastaYatis"
               asp-action="Create"
               class="btn btn-main">
                Yeni Hasta Yatışı
            </a>
        }
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted">
                        Şu An Yatan
                    </div>

                    <h2 class="text-danger mb-0">
                        @ViewBag.AktifYatanHasta
                    </h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted">
                        Bugün Yatan
                    </div>

                    <h2 class="mb-0">
                        @ViewBag.BugunYatanHasta
                    </h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted">
                        Bugün Taburcu
                    </div>

                    <h2 class="text-success mb-0">
                        @ViewBag.BugunTaburcu
                    </h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted">
                        Boş Yatak
                    </div>

                    <h2 class="text-primary mb-0">
                        @ViewBag.BosYatak
                    </h2>
                </div>
            </div>
        </div>
    </div>

    <form asp-controller="HastaYatis"
          asp-action="Index"
          method="get"
          class="row g-2 mb-4">

        <div class="col-lg-4">
            <input type="text"
                   name="arama"
                   value="@ViewBag.Arama"
                   class="form-control"
                   placeholder="TC, hasta, doktor veya yatış nedeni ara..." />
        </div>

        <div class="col-lg-3">
            <select name="servisId"
                    asp-items="ViewBag.Servisler"
                    class="form-select">

                <option value="">
                    Tüm Servisler
                </option>
            </select>
        </div>

        <div class="col-lg-2">
            <select name="durum"
                    asp-items="ViewBag.Durumlar"
                    class="form-select">

                <option value="">
                    Tüm Durumlar
                </option>
            </select>
        </div>

        <div class="col-lg-1">
            <button type="submit"
                    class="btn btn-main w-100">
                Ara
            </button>
        </div>

        <div class="col-lg-2">
            <a asp-controller="HastaYatis"
               asp-action="Index"
               class="btn btn-outline-secondary w-100">
                Temizle
            </a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Hasta</th>
                    <th>Yatış Tarihi</th>
                    <th>Doktor</th>
                    <th>Servis / Oda / Yatak</th>
                    <th>Yatış Türü</th>
                    <th>Ön Tanı</th>
                    <th>Durum</th>
                    <th style="min-width: 190px;">
                        İşlemler
                    </th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="8"
                            class="text-center text-muted">
                            Yatış kaydı bulunamadı.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var yatis in Model)
                    {
                        bool hastaYatiyorMu =
                            yatis.Durum == "Yatıyor";

                        <tr>
                            <td>
                                <strong>
                                    @yatis.Hasta?.Ad
                                    @yatis.Hasta?.Soyad
                                </strong>

                                <br />

                                <small class="text-muted">
                                    @yatis.Hasta?.TcKimlikNo
                                </small>

                                <br />

                                <small>
                                    Kan:
                                    @(yatis.Hasta?.KanGrubu ?? "-")
                                </small>
                            </td>

                            <td>
                                @yatis.YatisTarihi.ToString(
                                    "dd.MM.yyyy HH:mm"
                                )
                            </td>

                            <td>
                                @yatis.Doktor?.Unvan
                                @yatis.Doktor?.Ad
                                @yatis.Doktor?.Soyad
                            </td>

                            <td>
                                <strong>
                                    @yatis.Yatak?.Oda?.Servis?.ServisAdi
                                </strong>

                                <br />

                                Oda:
                                @yatis.Yatak?.Oda?.OdaNo

                                <br />

                                Yatak:
                                @yatis.Yatak?.YatakNo
                            </td>

                            <td>
                                @yatis.YatisTuru
                            </td>

                            <td>
                                @(yatis.OnTani ?? "-")
                            </td>

                            <td>
                                @if (hastaYatiyorMu)
                                {
                                    <span class="badge bg-danger">
                                        Yatıyor
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Taburcu
                                    </span>

                                    @if (yatis.TaburcuTarihi.HasValue)
                                    {
                                        <br />

                                        <small class="text-muted">
                                            @yatis.TaburcuTarihi.Value.ToString(
                                                "dd.MM.yyyy HH:mm"
                                            )
                                        </small>
                                    }
                                }
                            </td>

                            <td>
                                <a asp-controller="HastaYatis"
                                   asp-action="Details"
                                   asp-route-id="@yatis.HastaYatisId"
                                   class="btn btn-sm btn-info mb-1">
                                    Detay
                                </a>

                                @if (
                                    hastaYatiyorMu &&
                                    taburcuYetkisiVarMi
                                )
                                {
                                    <a asp-controller="HastaYatis"
                                       asp-action="Taburcu"
                                       asp-route-id="@yatis.HastaYatisId"
                                       class="btn btn-sm btn-success mb-1">
                                        Taburcu Et
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>