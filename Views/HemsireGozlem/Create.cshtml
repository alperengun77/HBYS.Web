@model HBYS.Web.Models.HemsireGozlem

@{
    ViewData["Title"] = "Yeni Hemşire Gözlemi";
}

<div class="page-card">
    <div class="mb-4">
        <h3>🩺 Yeni Hemşire Gözlem Kaydı</h3>

        <p class="text-muted mb-0">
            Yatan hastanın hayati bulgularını
            ve günlük bakım bilgilerini kaydet.
        </p>
    </div>

    <form asp-controller="HemsireGozlem"
          asp-action="Create"
          method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>1. Hasta ve Gözlem Tarihi</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="HastaYatisId"
                               class="form-label">
                            Yatan Hasta
                        </label>

                        <select asp-for="HastaYatisId"
                                asp-items="ViewBag.HastaYatislari"
                                class="form-select">

                            <option value="">
                                Yatan hasta seçiniz
                            </option>
                        </select>

                        <span asp-validation-for="HastaYatisId"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="GozlemTarihi"
                               class="form-label">
                            Gözlem Tarihi
                        </label>

                        <input asp-for="GozlemTarihi"
                               type="datetime-local"
                               step="60"
                               max="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                               value="@Model.GozlemTarihi.ToString("yyyy-MM-ddTHH:mm")"
                               class="form-control" />

                        <span asp-validation-for="GozlemTarihi"
                              class="text-danger">
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>2. Hayati Bulgular</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="Ates"
                               class="form-label">
                            Ateş
                        </label>

                        <div class="input-group">
                            <input asp-for="Ates"
                                   type="number"
                                   step="0.1"
                                   min="30"
                                   max="45"
                                   class="form-control"
                                   placeholder="36.5" />

                            <span class="input-group-text">
                                °C
                            </span>
                        </div>

                        <span asp-validation-for="Ates"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Nabiz"
                               class="form-label">
                            Nabız
                        </label>

                        <div class="input-group">
                            <input asp-for="Nabiz"
                                   type="number"
                                   min="20"
                                   max="250"
                                   class="form-control" />

                            <span class="input-group-text">
                                /dk
                            </span>
                        </div>

                        <span asp-validation-for="Nabiz"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TansiyonSistolik"
                               class="form-label">
                            Büyük Tansiyon
                        </label>

                        <input asp-for="TansiyonSistolik"
                               type="number"
                               min="50"
                               max="250"
                               class="form-control" />

                        <span asp-validation-for="TansiyonSistolik"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TansiyonDiastolik"
                               class="form-label">
                            Küçük Tansiyon
                        </label>

                        <input asp-for="TansiyonDiastolik"
                               type="number"
                               min="30"
                               max="180"
                               class="form-control" />

                        <span asp-validation-for="TansiyonDiastolik"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="OksijenSaturasyonu"
                               class="form-label">
                            Oksijen
                        </label>

                        <div class="input-group">
                            <input asp-for="OksijenSaturasyonu"
                                   type="number"
                                   min="50"
                                   max="100"
                                   class="form-control" />

                            <span class="input-group-text">
                                %
                            </span>
                        </div>

                        <span asp-validation-for="OksijenSaturasyonu"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="SolunumSayisi"
                               class="form-label">
                            Solunum
                        </label>

                        <div class="input-group">
                            <input asp-for="SolunumSayisi"
                                   type="number"
                                   min="5"
                                   max="80"
                                   class="form-control" />

                            <span class="input-group-text">
                                /dk
                            </span>
                        </div>

                        <span asp-validation-for="SolunumSayisi"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="KanSekeri"
                               class="form-label">
                            Kan Şekeri
                        </label>

                        <div class="input-group">
                            <input asp-for="KanSekeri"
                                   type="number"
                                   min="20"
                                   max="600"
                                   class="form-control" />

                            <span class="input-group-text">
                                mg/dL
                            </span>
                        </div>

                        <span asp-validation-for="KanSekeri"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="AgriDuzeyi"
                               class="form-label">
                            Ağrı Düzeyi
                        </label>

                        <input asp-for="AgriDuzeyi"
                               type="number"
                               min="0"
                               max="10"
                               class="form-control" />

                        <span asp-validation-for="AgriDuzeyi"
                              class="text-danger">
                        </span>

                        <small class="text-muted">
                            0 ağrı yok, 10 en yüksek ağrı.
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5>3. Hasta Takibi</h5>
                <hr />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="BilincDurumu"
                               class="form-label">
                            Bilinç Durumu
                        </label>

                        <select asp-for="BilincDurumu"
                                asp-items="ViewBag.BilincDurumlari"
                                class="form-select">

                            <option value="">
                                Seçiniz
                            </option>
                        </select>

                        <span asp-validation-for="BilincDurumu"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="BeslenmeDurumu"
                               class="form-label">
                            Beslenme Durumu
                        </label>

                        <select asp-for="BeslenmeDurumu"
                                asp-items="ViewBag.BeslenmeDurumlari"
                                class="form-select">

                            <option value="">
                                Seçiniz
                            </option>
                        </select>

                        <span asp-validation-for="BeslenmeDurumu"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="IdrarMiktari"
                               class="form-label">
                            İdrar Miktarı
                        </label>

                        <div class="input-group">
                            <input asp-for="IdrarMiktari"
                                   type="number"
                                   min="0"
                                   max="10000"
                                   class="form-control" />

                            <span class="input-group-text">
                                ml
                            </span>
                        </div>

                        <span asp-validation-for="IdrarMiktari"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="VerilenIlaclar"
                               class="form-label">
                            Verilen İlaçlar
                        </label>

                        <textarea asp-for="VerilenIlaclar"
                                  class="form-control"
                                  rows="4"
                                  placeholder="İlaç adı, doz ve uygulama saati...">
                        </textarea>

                        <span asp-validation-for="VerilenIlaclar"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SerumTakibi"
                               class="form-label">
                            Serum Takibi
                        </label>

                        <textarea asp-for="SerumTakibi"
                                  class="form-control"
                                  rows="4"
                                  placeholder="Serum türü, miktarı ve takip bilgileri...">
                        </textarea>

                        <span asp-validation-for="SerumTakibi"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="BakimNotu"
                               class="form-label">
                            Günlük Bakım Notu
                        </label>

                        <textarea asp-for="BakimNotu"
                                  class="form-control"
                                  rows="5"
                                  placeholder="Hastanın genel durumu, yapılan bakım ve gözlem notları...">
                        </textarea>

                        <span asp-validation-for="BakimNotu"
                              class="text-danger">
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-danger shadow-sm mb-4">
            <div class="card-body">
                <h5 class="text-danger">
                    4. Kritik Durum
                </h5>

                <hr />

                <div class="form-check mb-3">
                    <input asp-for="KritikDurumVarMi"
                           class="form-check-input"
                           id="kritikDurumInput" />

                    <label asp-for="KritikDurumVarMi"
                           class="form-check-label fw-bold">
                        Kritik durum bulunmaktadır
                    </label>
                </div>

                <div id="kritikNotAlani">
                    <label asp-for="KritikDurumNotu"
                           class="form-label">
                        Kritik Durum Açıklaması
                    </label>

                    <textarea asp-for="KritikDurumNotu"
                              class="form-control"
                              rows="4"
                              placeholder="Kritik durumun ayrıntısını ve yapılan işlemi yazınız...">
                    </textarea>

                    <span asp-validation-for="KritikDurumNotu"
                          class="text-danger">
                    </span>
                </div>
            </div>
        </div>

        <button type="submit"
                class="btn btn-main">
            Gözlem Kaydını Oluştur
        </button>

        <a asp-controller="HemsireGozlem"
           asp-action="Index"
           class="btn btn-secondary">
            Geri Dön
        </a>
    </form>
</div>

<script>
    document.addEventListener(
        "DOMContentLoaded",
        function () {
            const kritikInput =
                document.getElementById(
                    "kritikDurumInput"
                );

            const kritikNotAlani =
                document.getElementById(
                    "kritikNotAlani"
                );

            function kritikAlaniGuncelle() {
                kritikNotAlani.style.display =
                    kritikInput.checked
                        ? "block"
                        : "none";
            }

            kritikInput.addEventListener(
                "change",
                kritikAlaniGuncelle
            );

            kritikAlaniGuncelle();
        }
    );
</script>