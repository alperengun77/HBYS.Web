@model HBYS.Web.Models.HemsireGozlem

@{
    ViewData["Title"] =
        "Hemşire Gözlem Detayı";

    bool duzenlemeYetkisiVarMi =
        ViewBag.DuzenlemeYetkisiVarMi == true;

    bool adminMi =
        ViewBag.AdminMi == true;
}

<div class="print-header">
    <h2>HBYS Web</h2>
    <h4>Hemşire Gözlem Formu</h4>

    <p>
        Yazdırma Tarihi:
        @DateTime.Now.ToString("dd.MM.yyyy HH:mm")
    </p>
</div>

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3>🩺 Hemşire Gözlem Detayı</h3>

            <p class="text-muted mb-0">
                Gözlem No:
                <strong>
                    @Model.HemsireGozlemId
                </strong>
            </p>
        </div>

        <div class="d-flex gap-2 no-print">
            <button type="button"
                    onclick="window.print()"
                    class="btn btn-main">
                Yazdır
            </button>

            @if (duzenlemeYetkisiVarMi)
            {
                <a asp-controller="HemsireGozlem"
                   asp-action="Edit"
                   asp-route-id="@Model.HemsireGozlemId"
                   class="btn btn-warning">
                    Güncelle
                </a>
            }

            <a asp-controller="HemsireGozlem"
               asp-action="Gecmis"
               asp-route-hastaYatisId="@Model.HastaYatisId"
               class="btn btn-secondary">
                Geri Dön
            </a>
        </div>
    </div>

    @if (Model.KritikDurumVarMi)
    {
        <div class="alert alert-danger">
            <strong>⚠ Kritik Durum:</strong>
            @Model.KritikDurumNotu
        </div>
    }

    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5>Hasta Bilgileri</h5>
                    <hr />

                    <p>
                        <strong>Hasta:</strong>
                        @Model.HastaYatis?.Hasta?.Ad
                        @Model.HastaYatis?.Hasta?.Soyad
                    </p>

                    <p>
                        <strong>TC:</strong>
                        @Model.HastaYatis?.Hasta?.TcKimlikNo
                    </p>

                    <p>
                        <strong>Kan Grubu:</strong>
                        @(Model.HastaYatis?.Hasta?.KanGrubu ?? "-")
                    </p>

                    <p>
                        <strong>Servis:</strong>
                        @Model.HastaYatis?.Yatak?.Oda?.Servis?.ServisAdi
                    </p>

                    <p>
                        <strong>Oda / Yatak:</strong>
                        @Model.HastaYatis?.Yatak?.Oda?.OdaNo
                        /
                        @Model.HastaYatis?.Yatak?.YatakNo
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5>Gözlem Bilgileri</h5>
                    <hr />

                    <p>
                        <strong>Gözlem Tarihi:</strong>
                        @Model.GozlemTarihi.ToString(
                            "dd.MM.yyyy HH:mm"
                        )
                    </p>

                    <p>
                        <strong>Kaydeden:</strong>
                        @Model.KaydedenKullanici?.AdSoyad
                    </p>

                    <p>
                        <strong>Bilinç:</strong>
                        @(Model.BilincDurumu ?? "-")
                    </p>

                    <p>
                        <strong>Beslenme:</strong>
                        @(Model.BeslenmeDurumu ?? "-")
                    </p>

                    <p>
                        <strong>Ağrı Düzeyi:</strong>
                        @(Model.AgriDuzeyi?.ToString() ?? "-")
                    </p>

                    <p>
                        <strong>İdrar Miktarı:</strong>
                        @(Model.IdrarMiktari?.ToString() ?? "-")
                        ml
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5>Sorumlu Doktor</h5>
                    <hr />

                    <p>
                        <strong>Doktor:</strong>
                        @Model.HastaYatis?.Doktor?.Unvan
                        @Model.HastaYatis?.Doktor?.Ad
                        @Model.HastaYatis?.Doktor?.Soyad
                    </p>

                    <p>
                        <strong>Poliklinik:</strong>
                        @Model.HastaYatis?.Doktor?.Poliklinik?.PoliklinikAdi
                    </p>

                    <p>
                        <strong>Yatış Tarihi:</strong>
                        @Model.HastaYatis?.YatisTarihi.ToString(
                            "dd.MM.yyyy HH:mm"
                        )
                    </p>

                    <p>
                        <strong>Yatış Nedeni:</strong>
                        @Model.HastaYatis?.YatisNedeni
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body">
            <h5>Hayati Bulgular</h5>
            <hr />

            <div class="row text-center">
                <div class="col-md-2">
                    <div class="border rounded p-3">
                        <small class="text-muted">
                            Ateş
                        </small>

                        <h4>
                            @(Model.Ates?.ToString("0.0") ?? "-")
                        </h4>

                        <small>°C</small>
                    </div>
                </div>

                <div class="col-md-2">
                    <div class="border rounded p-3">
                        <small class="text-muted">
                            Nabız
                        </small>

                        <h4>
                            @(Model.Nabiz?.ToString() ?? "-")
                        </h4>

                        <small>/dk</small>
                    </div>
                </div>

                <div class="col-md-2">
                    <div class="border rounded p-3">
                        <small class="text-muted">
                            Tansiyon
                        </small>

                        <h4>
                            @(Model.TansiyonSistolik?.ToString() ?? "-")
                            /
                            @(Model.TansiyonDiastolik?.ToString() ?? "-")
                        </h4>
                    </div>
                </div>

                <div class="col-md-2">
                    <div class="border rounded p-3">
                        <small class="text-muted">
                            Oksijen
                        </small>

                        <h4>
                            @(Model.OksijenSaturasyonu?.ToString() ?? "-")
                        </h4>

                        <small>%</small>
                    </div>
                </div>

                <div class="col-md-2">
                    <div class="border rounded p-3">
                        <small class="text-muted">
                            Solunum
                        </small>

                        <h4>
                            @(Model.SolunumSayisi?.ToString() ?? "-")
                        </h4>

                        <small>/dk</small>
                    </div>
                </div>

                <div class="col-md-2">
                    <div class="border rounded p-3">
                        <small class="text-muted">
                            Kan Şekeri
                        </small>

                        <h4>
                            @(Model.KanSekeri?.ToString() ?? "-")
                        </h4>

                        <small>mg/dL</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5>İlaç ve Serum Takibi</h5>
                    <hr />

                    <p>
                        <strong>Verilen İlaçlar:</strong>
                    </p>

                    <div class="border rounded p-3 bg-light mb-3">
                        @(Model.VerilenIlaclar ?? "İlaç bilgisi girilmedi.")
                    </div>

                    <p>
                        <strong>Serum Takibi:</strong>
                    </p>

                    <div class="border rounded p-3 bg-light">
                        @(Model.SerumTakibi ?? "Serum bilgisi girilmedi.")
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5>Bakım Notu</h5>
                    <hr />

                    <div class="border rounded p-3 bg-light">
                        @(Model.BakimNotu ?? "Bakım notu girilmedi.")
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (adminMi)
    {
        <form asp-controller="HemsireGozlem"
              asp-action="Delete"
              asp-route-id="@Model.HemsireGozlemId"
              method="post"
              class="mt-4 no-print"
              onsubmit="return confirm('Bu gözlem kaydı silinsin mi?');">

            @Html.AntiForgeryToken()

            <button type="submit"
                    class="btn btn-danger">
                Gözlem Kaydını Sil
            </button>
        </form>
    }
</div>