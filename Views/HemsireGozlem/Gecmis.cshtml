@model List<HBYS.Web.Models.HemsireGozlem>

@{
    ViewData["Title"] =
        "Hemşire Gözlem Geçmişi";

    HBYS.Web.Models.HastaYatis? yatis =
        ViewBag.HastaYatis as
        HBYS.Web.Models.HastaYatis;

    bool kayitYetkisiVarMi =
        ViewBag.KayitYetkisiVarMi == true;

    bool adminMi =
        ViewBag.AdminMi == true;

    bool doktorMu =
        ViewBag.DoktorMu == true;

    bool hemsireMi =
        ViewBag.HemsireMi == true;

    int? aktifKullaniciId =
        ViewBag.AktifKullaniciId as int?;
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3>📋 Hemşire Gözlem Geçmişi</h3>

            <p class="text-muted mb-0">
                @yatis?.Hasta?.Ad
                @yatis?.Hasta?.Soyad
                adlı hastanın tüm gözlem kayıtları.
            </p>
        </div>

        <div class="d-flex gap-2">
            @if (kayitYetkisiVarMi)
            {
                <a asp-controller="HemsireGozlem"
                   asp-action="Create"
                   asp-route-hastaYatisId="@yatis?.HastaYatisId"
                   class="btn btn-main">
                    Yeni Gözlem
                </a>
            }

            <a asp-controller="HemsireGozlem"
               asp-action="Index"
               class="btn btn-secondary">
                Geri Dön
            </a>
        </div>
    </div>

    <div class="alert alert-info">
        <div class="row">
            <div class="col-md-3">
                <strong>Hasta:</strong>

                <br />

                @yatis?.Hasta?.Ad
                @yatis?.Hasta?.Soyad
            </div>

            <div class="col-md-3">
                <strong>TC:</strong>

                <br />

                @yatis?.Hasta?.TcKimlikNo
            </div>

            <div class="col-md-3">
                <strong>Servis:</strong>

                <br />

                @yatis?.Yatak?.Oda?.Servis?.ServisAdi
            </div>

            <div class="col-md-3">
                <strong>Oda / Yatak:</strong>

                <br />

                @yatis?.Yatak?.Oda?.OdaNo
                /
                @yatis?.Yatak?.YatakNo
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Tarih</th>
                    <th>Hayati Bulgular</th>
                    <th>Bilinç / Ağrı</th>
                    <th>İlaç / Serum</th>
                    <th>Kaydeden</th>
                    <th>Durum</th>
                    <th style="min-width: 170px;">
                        İşlemler
                    </th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7"
                            class="text-center text-muted">
                            Bu hastaya ait gözlem kaydı bulunamadı.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var gozlem in Model)
                    {
                        bool duzenleyebilirMi =
                            adminMi ||
                            doktorMu ||
                            (
                                hemsireMi &&
                                aktifKullaniciId.HasValue &&
                                gozlem.KaydedenKullaniciId ==
                                aktifKullaniciId.Value
                            );

                        <tr class="@(gozlem.KritikDurumVarMi ? "table-danger" : "")">
                            <td>
                                <strong>
                                    @gozlem.GozlemTarihi.ToString(
                                        "dd.MM.yyyy"
                                    )
                                </strong>

                                <br />

                                @gozlem.GozlemTarihi.ToString(
                                    "HH:mm"
                                )
                            </td>

                            <td>
                                Ateş:
                                @(gozlem.Ates?.ToString("0.0") ?? "-")

                                <br />

                                Nabız:
                                @(gozlem.Nabiz?.ToString() ?? "-")

                                <br />

                                Tansiyon:
                                @(gozlem.TansiyonSistolik?.ToString() ?? "-")
                                /
                                @(gozlem.TansiyonDiastolik?.ToString() ?? "-")

                                <br />

                                Oksijen:
                                @(gozlem.OksijenSaturasyonu?.ToString() ?? "-")
                                %
                            </td>

                            <td>
                                Bilinç:
                                @(gozlem.BilincDurumu ?? "-")

                                <br />

                                Ağrı:
                                @(gozlem.AgriDuzeyi?.ToString() ?? "-")

                                <br />

                                Kan şekeri:
                                @(gozlem.KanSekeri?.ToString() ?? "-")
                            </td>

                            <td>
                                <small>
                                    @(gozlem.VerilenIlaclar ?? "İlaç yok")
                                </small>

                                <hr class="my-1" />

                                <small>
                                    @(gozlem.SerumTakibi ?? "Serum yok")
                                </small>
                            </td>

                            <td>
                                @gozlem.KaydedenKullanici?.AdSoyad
                            </td>

                            <td>
                                @if (gozlem.KritikDurumVarMi)
                                {
                                    <span class="badge bg-danger">
                                        Kritik
                                    </span>

                                    <br />

                                    <small>
                                        @gozlem.KritikDurumNotu
                                    </small>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        Normal Takip
                                    </span>
                                }
                            </td>

                            <td>
                                <a asp-controller="HemsireGozlem"
                                   asp-action="Details"
                                   asp-route-id="@gozlem.HemsireGozlemId"
                                   class="btn btn-sm btn-info mb-1">
                                    Detay
                                </a>

                                @if (
                                    duzenleyebilirMi &&
                                    yatis?.Durum == "Yatıyor"
                                )
                                {
                                    <a asp-controller="HemsireGozlem"
                                       asp-action="Edit"
                                       asp-route-id="@gozlem.HemsireGozlemId"
                                       class="btn btn-sm btn-warning mb-1">
                                        Güncelle
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
