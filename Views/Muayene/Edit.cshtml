@model HBYS.Web.Models.Muayene

@{
    ViewData["Title"] = "Muayene Güncelle";
}

<div class="page-card">
    <div class="mb-3">
        <h3>Muayene Güncelle</h3>

        <p class="text-muted mb-0">
            Muayenenin klinik bilgilerini düzenle.
            Hasta, doktor ve randevu bilgileri değiştirilemez.
        </p>
    </div>

    <form asp-controller="Muayene"
          asp-action="Edit"
          method="post">

        @Html.AntiForgeryToken()

        <input type="hidden"
               asp-for="MuayeneId" />

        <input type="hidden"
               asp-for="HastaId" />

        <input type="hidden"
               asp-for="DoktorId" />

        <input type="hidden"
               asp-for="RandevuId" />

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">
                    Hasta
                </label>

                <input type="text"
                       class="form-control"
                       readonly
                       value="@Model.Hasta?.TcKimlikNo - @Model.Hasta?.Ad @Model.Hasta?.Soyad" />
            </div>

            <div class="col-md-6">
                <label class="form-label">
                    Doktor
                </label>

                <input type="text"
                       class="form-control"
                       readonly
                       value="@Model.Doktor?.Unvan @Model.Doktor?.Ad @Model.Doktor?.Soyad" />
            </div>

            <div class="col-md-6">
                <label class="form-label">
                    Bağlı Randevu
                </label>

                @if (Model.Randevu != null)
                {
                    <input type="text"
                           class="form-control"
                           readonly
                           value="@Model.Randevu.RandevuTarihiSaati.ToString("dd.MM.yyyy HH:mm")" />
                }
                else
                {
                    <input type="text"
                           class="form-control is-invalid"
                           readonly
                           value="Bu muayenenin bağlı randevusu bulunmuyor" />
                }

                <span asp-validation-for="RandevuId"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="MuayeneTarihi"
                       class="form-label">
                    Muayene Tarihi
                </label>

                <input asp-for="MuayeneTarihi"
                       type="datetime-local"
                       step="60"
                       max="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                       class="form-control"
                       value="@Model.MuayeneTarihi.ToString("yyyy-MM-ddTHH:mm")" />

                <span asp-validation-for="MuayeneTarihi"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-12">
                <label asp-for="Sikayet"
                       class="form-label">
                    Şikayet
                </label>

                <textarea asp-for="Sikayet"
                          class="form-control"
                          rows="3">
                </textarea>

                <span asp-validation-for="Sikayet"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-12">
                <label asp-for="Tani"
                       class="form-label">
                    Tanı
                </label>

                <textarea asp-for="Tani"
                          class="form-control"
                          rows="3">
                </textarea>

                <span asp-validation-for="Tani"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-12">
                <label asp-for="TedaviNotu"
                       class="form-label">
                    Tedavi Notu
                </label>

                <textarea asp-for="TedaviNotu"
                          class="form-control"
                          rows="4">
                </textarea>

                <span asp-validation-for="TedaviNotu"
                      class="text-danger">
                </span>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit"
                    class="btn btn-main">
                Güncelle
            </button>

            <a asp-controller="Muayene"
               asp-action="Index"
               class="btn btn-secondary">
                Geri Dön
            </a>
        </div>
    </form>
</div>