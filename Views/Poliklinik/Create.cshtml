@model HBYS.Web.Models.Poliklinik

@{
    ViewData["Title"] = "Yeni Poliklinik Ekle";
}

<div class="page-card">
    <div class="mb-3">
        <h3>Yeni Poliklinik Ekle</h3>
        <p class="text-muted mb-0">Yeni poliklinik kaydı oluştur.</p>
    </div>

    <form asp-controller="Poliklinik" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="PoliklinikAdi" class="form-label">Poliklinik Adı</label>
                <input asp-for="PoliklinikAdi" class="form-control" />
                <span asp-validation-for="PoliklinikAdi" class="text-danger"></span>
            </div>

            <div class="col-md-12">
                <label asp-for="Aciklama" class="form-label">Açıklama</label>
                <textarea asp-for="Aciklama" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Aciklama" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-main">Kaydet</button>
            <a asp-controller="Poliklinik" asp-action="Index" class="btn btn-secondary">Geri Dön</a>
        </div>
    </form>
</div>
