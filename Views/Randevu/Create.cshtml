@model HBYS.Web.Models.Randevu

@{
    ViewData["Title"] = "Yeni Randevu Ekle";

    bool doktorMu = ViewBag.DoktorMu == true;
}

<div class="page-card">
    <h3>Yeni Randevu Ekle</h3>

    <p class="text-muted">
        Hasta, poliklinik, doktor, tarih ve boş saat bilgilerini seçerek yeni randevu oluştur.
    </p>

    <form asp-controller="Randevu"
          asp-action="Create"
          method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="HastaId"
                       class="form-label">
                    Hasta
                </label>

                <select asp-for="HastaId"
                        asp-items="ViewBag.Hastalar"
                        class="form-select">

                    <option value="">
                        Hasta seçiniz
                    </option>
                </select>

                <span asp-validation-for="HastaId"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="PoliklinikId"
                       class="form-label">
                    Poliklinik
                </label>

                @if (doktorMu)
                {
                    <select asp-for="PoliklinikId"
                            asp-items="ViewBag.Poliklinikler"
                            id="poliklinikSelect"
                            class="form-select"
                            disabled>

                        <option value="">
                            Poliklinik seçiniz
                        </option>
                    </select>

                    <input type="hidden"
                           asp-for="PoliklinikId" />
                }
                else
                {
                    <select asp-for="PoliklinikId"
                            asp-items="ViewBag.Poliklinikler"
                            id="poliklinikSelect"
                            class="form-select">

                        <option value="">
                            Poliklinik seçiniz
                        </option>
                    </select>
                }

                <span asp-validation-for="PoliklinikId"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="DoktorId"
                       class="form-label">
                    Doktor
                </label>

                @if (doktorMu)
                {
                    <select asp-for="DoktorId"
                            asp-items="ViewBag.Doktorlar"
                            id="doktorSelect"
                            class="form-select"
                            disabled>

                        <option value="">
                            Doktor seçiniz
                        </option>
                    </select>

                    <input type="hidden"
                           asp-for="DoktorId" />
                }
                else
                {
                    <select asp-for="DoktorId"
                            asp-items="ViewBag.Doktorlar"
                            id="doktorSelect"
                            class="form-select">

                        <option value="">
                            Doktor seçiniz
                        </option>
                    </select>
                }

                <span asp-validation-for="DoktorId"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-3 mb-3">
                <label for="randevuTarihiInput"
                       class="form-label">
                    Randevu Tarihi
                </label>

                <input type="date"
                       id="randevuTarihiInput"
                       name="randevuTarihi"
                       value="@ViewBag.RandevuTarihi"
                       min="@ViewBag.MinRandevuTarihi"
                       class="form-control" />
            </div>

            <div class="col-md-3 mb-3">
                <label for="randevuSaatiSelect"
                       class="form-label">
                    Randevu Saati
                </label>

                <select id="randevuSaatiSelect"
                        name="randevuSaati"
                        class="form-select">

                    <option value="">
                        Boş saat seçiniz
                    </option>

                    @foreach (string saat in ViewBag.Saatler)
                    {
                        if (ViewBag.RandevuSaati == saat)
                        {
                            <option value="@saat"
                                    selected>
                                @saat
                            </option>
                        }
                        else
                        {
                            <option value="@saat">
                                @saat
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-6 mb-3">
                <span asp-validation-for="RandevuTarihiSaati"
                      class="text-danger">
                </span>

                <small id="saatBilgisi"
                       class="text-muted d-block">
                    Doktor ve tarih seçildiğinde yalnızca boş randevu saatleri gösterilir.
                </small>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Durum"
                       class="form-label">
                    Durum
                </label>

                <select asp-for="Durum"
                        class="form-select">

                    <option value="Bekliyor">
                        Bekliyor
                    </option>

                    <option value="Tamamlandi">
                        Tamamlandı
                    </option>

                    <option value="Iptal">
                        İptal
                    </option>
                </select>

                <span asp-validation-for="Durum"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="Aciklama"
                       class="form-label">
                    Açıklama
                </label>

                <textarea asp-for="Aciklama"
                          class="form-control"
                          rows="3">
                </textarea>

                <span asp-validation-for="Aciklama"
                      class="text-danger">
                </span>
            </div>
        </div>

        <button type="submit"
                class="btn btn-main">
            Kaydet
        </button>

        <a asp-controller="Randevu"
           asp-action="Index"
           class="btn btn-secondary">
            Geri Dön
        </a>
    </form>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const poliklinikSelect =
            document.getElementById("poliklinikSelect");

        const doktorSelect =
            document.getElementById("doktorSelect");

        const tarihInput =
            document.getElementById("randevuTarihiInput");

        const saatSelect =
            document.getElementById("randevuSaatiSelect");

        const saatBilgisi =
            document.getElementById("saatBilgisi");

        const doktorMu =
            "@doktorMu".toLowerCase() === "true";

        const doktorGetirUrl =
            '@Url.Action("DoktorlariGetir", "Randevu")';

        const bosSaatGetirUrl =
            '@Url.Action("BosSaatleriGetir", "Randevu")';

        function saatleriTemizle(mesaj) {
            saatSelect.innerHTML = "";

            saatSelect.appendChild(
                new Option(mesaj, "")
            );
        }

        function bosSaatleriYukle() {
            const doktorId =
                doktorSelect
                    ? doktorSelect.value
                    : "";

            const tarih =
                tarihInput
                    ? tarihInput.value
                    : "";

            if (!doktorId || !tarih) {
                saatleriTemizle(
                    "Önce doktor ve tarih seçiniz"
                );

                saatBilgisi.textContent =
                    "Doktor ve tarih seçildiğinde yalnızca boş randevu saatleri gösterilir.";

                return;
            }

            saatleriTemizle(
                "Boş saatler yükleniyor..."
            );

            fetch(
                `${bosSaatGetirUrl}?doktorId=${encodeURIComponent(doktorId)}&randevuTarihi=${encodeURIComponent(tarih)}`
            )
                .then(response => {
                    if (!response.ok) {
                        throw new Error(
                            "Saatler alınamadı."
                        );
                    }

                    return response.json();
                })
                .then(saatler => {
                    saatSelect.innerHTML = "";

                    if (
                        !saatler ||
                        saatler.length === 0
                    ) {
                        saatSelect.appendChild(
                            new Option(
                                "Bu gün için boş saat yok",
                                ""
                            )
                        );

                        saatBilgisi.textContent =
                            "Seçilen doktorun bu tarihte kullanılabilir randevu saati bulunmuyor.";

                        return;
                    }

                    saatSelect.appendChild(
                        new Option(
                            "Boş saat seçiniz",
                            ""
                        )
                    );

                    saatler.forEach(function (saat) {
                        saatSelect.appendChild(
                            new Option(saat, saat)
                        );
                    });

                    saatBilgisi.textContent =
                        "Dolu ve geçmiş saatler listeden çıkarıldı.";
                })
                .catch(() => {
                    saatleriTemizle(
                        "Saatler yüklenemedi"
                    );

                    saatBilgisi.textContent =
                        "Boş saatler yüklenirken bir hata oluştu.";
                });
        }

        if (
            poliklinikSelect &&
            doktorSelect &&
            !doktorMu
        ) {
            poliklinikSelect.addEventListener(
                "change",
                function () {
                    const poliklinikId =
                        this.value;

                    doktorSelect.innerHTML = "";

                    doktorSelect.appendChild(
                        new Option(
                            "Doktor seçiniz",
                            ""
                        )
                    );

                    saatleriTemizle(
                        "Önce doktor seçiniz"
                    );

                    if (!poliklinikId) {
                        return;
                    }

                    fetch(
                        `${doktorGetirUrl}?poliklinikId=${encodeURIComponent(poliklinikId)}`
                    )
                        .then(response =>
                            response.json()
                        )
                        .then(doktorlar => {
                            doktorlar.forEach(
                                function (doktor) {
                                    doktorSelect
                                        .appendChild(
                                            new Option(
                                                doktor.adSoyad,
                                                doktor.doktorId
                                            )
                                        );
                                }
                            );
                        });
                }
            );
        }

        if (doktorSelect) {
            doktorSelect.addEventListener(
                "change",
                bosSaatleriYukle
            );
        }

        if (tarihInput) {
            tarihInput.addEventListener(
                "change",
                bosSaatleriYukle
            );
        }
    });
</script>