@model List<HBYS.Web.Models.Muayene>

@{
    ViewData["Title"] = "Muayene Raporu";
}

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Muayene Raporu</h3>
            <p class="text-muted mb-0">Tarih aralığına göre muayene kayıtlarını görüntüle.</p>
        </div>

        <a asp-controller="Rapor" asp-action="Index" class="btn btn-secondary">
            Raporlara Dön
        </a>
    </div>

    <form asp-controller="Rapor" asp-action="MuayeneRaporu" method="get" class="row g-2 mb-4">
        <div class="col-md-4">
            <input type="date" name="baslangicTarihi" value="@ViewBag.BaslangicTarihi" class="form-control" />
        </div>

        <div class="col-md-4">
            <input type="date" name="bitisTarihi" value="@ViewBag.BitisTarihi" class="form-control" />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-main w-100">Getir</button>
        </div>
    </form>

    <div class="alert alert-primary">
        Seçilen aralıktaki toplam muayene sayısı: <strong>@ViewBag.Toplam</strong>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Muayene Tarihi</th>
                    <th>Hasta</th>
                    <th>Doktor</th>
                    <th>Şikayet</th>
                    <th>Tanı</th>
                    <th>Tedavi Notu</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            Seçilen tarih aralığında muayene bulunamadı.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var muayene in Model)
                    {
                        <tr>
                            <td>@muayene.MuayeneTarihi.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @muayene.Hasta?.Ad @muayene.Hasta?.Soyad
                                <br />
                                <small class="text-muted">@muayene.Hasta?.TcKimlikNo</small>
                            </td>
                            <td>@muayene.Doktor?.Ad @muayene.Doktor?.Soyad</td>
                            <td>@muayene.Sikayet</td>
                            <td>@muayene.Tani</td>
                            <td>@muayene.TedaviNotu</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
