@model HBYS.Web.Models.Recete

@{
    ViewData["Title"] = "Reçete Detay";
}

<div class="print-header">
    <h2>HBYS Web</h2>
    <h4>Reçete Bilgi Formu</h4>

    <p>
        Yazdırma Tarihi:
        @DateTime.Now.ToString("dd.MM.yyyy HH:mm")
    </p>
</div>

<div class="page-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h3>Reçete Detay</h3>

            <p class="text-muted mb-0">
                Muayeneye bağlı reçete bilgileri.
            </p>
        </div>

        <div class="no-print">
            <button type="button"
                    onclick="window.print()"
                    class="btn btn-main">
                Yazdır
            </button>

            <a asp-controller="Recete"
               asp-action="Edit"
               asp-route-id="@Model.ReceteId"
               class="btn btn-warning">
                Güncelle
            </a>

            <a asp-controller="Recete"
               asp-action="Index"
               class="btn btn-secondary">
                Geri Dön
            </a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5>Hasta Bilgileri</h5>
                    <hr />

                    <p>
                        <strong>Hasta:</strong>
                        @Model.Muayene?.Hasta?.Ad
                        @Model.Muayene?.Hasta?.Soyad
                    </p>

                    <p>
                        <strong>TC Kimlik No:</strong>
                        @Model.Muayene?.Hasta?.TcKimlikNo
                    </p>

                    <p>
                        <strong>Telefon:</strong>
                        @Model.Muayene?.Hasta?.Telefon
                    </p>

                    <p>
                        <strong>Kan Grubu:</strong>
                        @Model.Muayene?.Hasta?.KanGrubu
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5>Doktor Bilgileri</h5>
                    <hr />

                    <p>
                        <strong>Doktor:</strong>
                        @Model.Muayene?.Doktor?.Unvan
                        @Model.Muayene?.Doktor?.Ad
                        @Model.Muayene?.Doktor?.Soyad
                    </p>

                    <p>
                        <strong>TC Kimlik No:</strong>
                        @Model.Muayene?.Doktor?.TcKimlikNo
                    </p>

                    <p>
                        <strong>E-posta:</strong>
                        @Model.Muayene?.Doktor?.Eposta
                    </p>

                    <p>
                        <strong>Telefon:</strong>
                        @Model.Muayene?.Doktor?.Telefon
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5>Muayene Bilgileri</h5>
                    <hr />

                    <p>
                        <strong>Muayene Tarihi:</strong>
                        @Model.Muayene?.MuayeneTarihi.ToString("dd.MM.yyyy HH:mm")
                    </p>

                    <p>
                        <strong>Tanı:</strong>
                        @Model.Muayene?.Tani
                    </p>

                    <p>
                        <strong>Şikayet:</strong>
                        @Model.Muayene?.Sikayet
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-card mt-4">
    <h5>İlaç Bilgileri</h5>
    <hr />

    <table class="table table-bordered align-middle">
        <tbody>
            <tr>
                <th style="width: 220px;">
                    İlaç Adı
                </th>

                <td>
                    @Model.IlacAdi
                </td>
            </tr>

            <tr>
                <th>Doz</th>
                <td>@Model.Doz</td>
            </tr>

            <tr>
                <th>Kullanım Şekli</th>
                <td>@Model.KullanimSekli</td>
            </tr>

            <tr>
                <th>Kullanım Süresi</th>
                <td>@Model.KullanimSuresi</td>
            </tr>

            <tr>
                <th>Açıklama</th>
                <td>@Model.Aciklama</td>
            </tr>

            <tr>
                <th>Kayıt Tarihi</th>

                <td>
                    @Model.KayitTarihi.ToString("dd.MM.yyyy HH:mm")
                </td>
            </tr>
        </tbody>
    </table>
</div>

<div class="page-card mt-4">
    <div class="row">
        <div class="col-md-6">
            <p>
                <strong>Doktor İmza:</strong>
            </p>

            <br />

            <p>
                ........................................
            </p>
        </div>

        <div class="col-md-6 text-end">
            <p>
                <strong>HBYS Web Reçete Çıktısı</strong>
            </p>

            <p class="text-muted">
                Bu belge staj projesi kapsamında oluşturulmuştur.
            </p>
        </div>
    </div>
</div>