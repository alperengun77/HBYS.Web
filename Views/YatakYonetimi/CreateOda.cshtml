@model HBYS.Web.Models.Oda

@{
    ViewData["Title"] = "Yeni Oda";
}

<div class="page-card">
    <h3>Yeni Oda Ekle</h3>

    <p class="text-muted">
        Bir servise bağlı yeni hasta odası oluştur.
    </p>

    <form asp-controller="YatakYonetimi"
          asp-action="CreateOda"
          method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="ServisId"
                       class="form-label">
                    Servis
                </label>

                <select asp-for="ServisId"
                        asp-items="ViewBag.Servisler"
                        class="form-select">

                    <option value="">
                        Servis seçiniz
                    </option>
                </select>

                <span asp-validation-for="ServisId"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="OdaNo"
                       class="form-label">
                    Oda Numarası
                </label>

                <input asp-for="OdaNo"
                       class="form-control"
                       placeholder="Örn: 201" />

                <span asp-validation-for="OdaNo"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="OdaTipi"
                       class="form-label">
                    Oda Tipi
                </label>

                <select asp-for="OdaTipi"
                        asp-items="ViewBag.OdaTipleri"
                        class="form-select">
                </select>

                <span asp-validation-for="OdaTipi"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="CinsiyetKisitlamasi"
                       class="form-label">
                    Cinsiyet Kısıtlaması
                </label>

                <select asp-for="CinsiyetKisitlamasi"
                        asp-items="ViewBag.CinsiyetKisitlamalari"
                        class="form-select">
                </select>

                <span asp-validation-for="CinsiyetKisitlamasi"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-12">
                <label asp-for="Aciklama"
                       class="form-label">
                    Açıklama
                </label>

                <textarea asp-for="Aciklama"
                          class="form-control"
                          rows="3"
                          placeholder="Odaya ait özel notlar...">
                </textarea>

                <span asp-validation-for="Aciklama"
                      class="text-danger">
                </span>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit"
                    class="btn btn-main">
                Kaydet
            </button>

            <a asp-controller="YatakYonetimi"
               asp-action="Index"
               class="btn btn-secondary">
                Geri Dön
            </a>
        </div>
    </form>
</div>