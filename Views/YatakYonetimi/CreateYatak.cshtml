@model HBYS.Web.Models.Yatak

@{
    ViewData["Title"] = "Yeni Yatak";
}

<div class="page-card">
    <h3>Yeni Yatak Ekle</h3>

    <p class="text-muted">
        Seçilen odaya yeni yatak ekle
        ve başlangıç durumunu belirle.
    </p>

    <form asp-controller="YatakYonetimi"
          asp-action="CreateYatak"
          method="post">

        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="OdaId"
                       class="form-label">
                    Oda
                </label>

                <select asp-for="OdaId"
                        asp-items="ViewBag.Odalar"
                        class="form-select">

                    <option value="">
                        Oda seçiniz
                    </option>
                </select>

                <span asp-validation-for="OdaId"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="YatakNo"
                       class="form-label">
                    Yatak Numarası
                </label>

                <input asp-for="YatakNo"
                       class="form-control"
                       placeholder="Örn: A veya 1" />

                <span asp-validation-for="YatakNo"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="Durum"
                       class="form-label">
                    Yatak Durumu
                </label>

                <select asp-for="Durum"
                        asp-items="ViewBag.YatakDurumlari"
                        class="form-select">
                </select>

                <span asp-validation-for="Durum"
                      class="text-danger">
                </span>

                <small class="text-muted">
                    Dolu durumu hasta yatışı sırasında
                    otomatik verilir.
                </small>
            </div>

            <div class="col-md-6">
                <label asp-for="Ozellik"
                       class="form-label">
                    Yatak Özelliği
                </label>

                <input asp-for="Ozellik"
                       class="form-control"
                       placeholder="Örn: Oksijen çıkışlı, monitörlü" />

                <span asp-validation-for="Ozellik"
                      class="text-danger">
                </span>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit"
                    class="btn btn-main">
                Kaydet
            </button>

            <a asp-controller="YatakYonetimi"
               asp-action="Index"
               class="btn btn-secondary">
                Geri Dön
            </a>
        </div>
    </form>
</div>